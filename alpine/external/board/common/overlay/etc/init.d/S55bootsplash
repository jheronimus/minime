#!/bin/sh

# S55bootsplash: run the minime animated boot splash before the UI starts.
# This script is intentionally simple: it reads a config file and, if
# enabled, blocks until the bootsplash binary exits.

CONFIG="/mnt/sdcard/.minime/config/bootsplash.cfg"

case "$1" in
start)
	if [ -f "$CONFIG" ]; then
		enabled=$(sed -n 's/^[[:space:]]*enabled[[:space:]]*=[[:space:]]*//p' "$CONFIG" | tail -1 | tr -d '[:space:]')
		[ "$enabled" = "0" ] && exit 0
	fi
	/usr/bin/bootsplash --fullscreen --config "$CONFIG" || true
	;;
stop|restart|reload)
	;;
*)
	echo "Usage: $0 {start|stop|restart|reload}"
	exit 1
	;;
esac

exit 0
