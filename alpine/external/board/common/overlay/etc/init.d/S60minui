#!/bin/sh

case "$1" in
    start)
        echo "Starting MinUI loop..."
        
        # Dynamic model detection
        model_dt=$(cat /proc/device-tree/model 2>/dev/null || echo "")
        case "$model_dt" in
            *SP*|*sp*)
                RGXX_MODEL="RG35xxSP"
                ;;
            *Plus*|*plus*|*PLUS*)
                RGXX_MODEL="RG35xxPlus"
                ;;
            *H*|*h*)
                if echo "$model_dt" | grep -qi "rg35xx h"; then
                    RGXX_MODEL="RG35xxH"
                else
                    RGXX_MODEL="RG35xx"
                fi
                ;;
            *28*)
                RGXX_MODEL="RG28xx"
                ;;
            *Cube*|*cube*)
                RGXX_MODEL="RGcubexx"
                ;;
            *)
                RGXX_MODEL="RG35xx"
                ;;
        esac
        export RGXX_MODEL
        
        # 1. Set graphics library paths
        # Detect Panfrost (mesa3d-from-source) vs libmali by checking which
        # kernel driver is actually loaded.
        if lsmod 2>/dev/null | grep -q "^panfrost "; then
            export LD_LIBRARY_PATH="/usr/lib:/mnt/sdcard/.system/bin"
            export LIBGL_DRIVERS_PATH="/usr/lib/dri"
            export GBM_BACKENDS_PATH="/usr/lib/gbm"
            export MESA_LOADER_DRIVER_OVERRIDE=panfrost
            export SDL_VIDEODRIVER=kmsdrm
        else
            export LD_LIBRARY_PATH="/mnt/sdcard/.system/bin"
        fi
        export USERDATA_PATH=/mnt/sdcard/.system/
        export HOME=/mnt/sdcard
        
        # Ensure backlight is visible; minui may later override via msettings.bin
        for bl in /sys/class/backlight/*/brightness; do
            [ -w "$bl" ] && echo 5 > "$bl" 2>/dev/null || true
        done
        
        # 2. Clear GPU Failure boot-loop sentinel on successful GUI launch
        rm -f /mnt/sdcard/.system/gpu_fail

        # Clear any stale next commands
        rm -f /tmp/next
        
        # DEBUG: MinUI auto-start disabled for troubleshooting.
        # Remove these two lines to re-enable automatic MinUI launch on boot.
        echo "MinUI auto-start disabled for debugging."
        echo "Run '/etc/init.d/S60minui start' manually to launch GUI."
        exit 0
        
        # Start MinUI lifecycle loop in background to let boot process finish.
        (
            while true; do
                if [ -f /tmp/poweroff ]; then
                    rm -f /tmp/poweroff
                    poweroff
                    exit 0
                fi
                
                /mnt/sdcard/.system/bin/minui < /dev/console > /tmp/minui.log 2>&1

                # Check for next command
                if [ -f /tmp/next ]; then
                    CMD=$(cat /tmp/next)
                    rm -f /tmp/next
                    eval "$CMD" < /dev/console > /dev/console 2>&1
                else
                    # Fallback or clean shutdown if no next action queued
                    sleep 3600
                    exit 0
                fi
            done
        ) &
        ;;
    stop)
        echo "Stopping MinUI..."
        killall minui 2>/dev/null
        ;;
    restart|reload)
        "$0" stop
        "$0" start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac

exit 0
