#!/bin/sh

DAEMON="bluealsa"
PIDFILE="/var/run/$DAEMON.pid"

BLUEALSA_ARGS="-p a2dp-sink -p a2dp-source"

# On-demand check
if [ "$1" = "start" ] && [ ! -f "/mnt/sdcard/.system/config/bluetooth/enabled" ]; then
	exit 0
fi

start() {
	printf 'Starting %s: ' "$DAEMON"
	start-stop-daemon --start --background --make-pidfile \
		--pidfile "$PIDFILE" --exec "/usr/bin/$DAEMON" \
		-- $BLUEALSA_ARGS
	status=$?
	if [ "$status" -eq 0 ]; then
		echo "OK"
	else
		echo "FAIL"
	fi
	return "$status"
}

stop() {
	printf 'Stopping %s: ' "$DAEMON"
	start-stop-daemon --stop --pidfile "$PIDFILE" \
		--exec "/usr/bin/$DAEMON"
	status=$?
	if [ "$status" -eq 0 ]; then
		echo "OK"
	else
		echo "FAIL"
	fi
	return "$status"
}

restart() {
	stop
	start
}

case "$1" in
	start|stop|restart)
		"$1";;
	*)
		echo "Usage: $0 {start|stop|restart}"
		exit 1
esac
