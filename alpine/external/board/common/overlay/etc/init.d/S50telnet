#!/bin/sh

PIDFILE="/var/run/telnetd.pid"

start() {
	printf "Starting telnetd: "
	if [ -s "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
		echo "already running"
		return 0
	fi

	/usr/sbin/telnetd -F -l /usr/bin/autologin &
	pid=$!
	printf '%s\n' "$pid" > "$PIDFILE"
	sleep 1
	if kill -0 "$pid" 2>/dev/null; then
		echo "OK"
	else
		rm -f "$PIDFILE"
		echo "FAIL"
		return 1
	fi
}

stop() {
	printf "Stopping telnetd: "
	if [ -s "$PIDFILE" ]; then
		kill "$(cat "$PIDFILE")" 2>/dev/null || true
	fi
	rm -f "$PIDFILE"
	echo "OK"
}

restart() {
	stop
	sleep 1
	start
}

case "$1" in
	start)
		start
		;;
	stop)
		stop
		;;
	restart|reload)
		restart
		;;
	*)
		echo "Usage: $0 {start|stop|restart}"
		exit 1
esac
