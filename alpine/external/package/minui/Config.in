config BR2_PACKAGE_MINUI
	bool "minui"
	select BR2_PACKAGE_LZ4
	select BR2_PACKAGE_LIBRETRO_COMMON
	help
	  Minimal launcher frontend and UI shell for minime.

	  https://github.com/minime-os/minui

if BR2_PACKAGE_MINUI

config BR2_PACKAGE_MINUI_EXTRAS
	bool "Include MinUI Extras"
	default y
	help
	  Build and stage additional emulators and tools from
	  MinUI Extras.

endif
