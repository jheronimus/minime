config BR2_PACKAGE_HOST_LLVM_SYSTEM
	bool "host llvm (system)"
	help
	  Use the Debian build container's preinstalled LLVM/Clang/libclc
	  toolchain (LLVM 22 from apt.llvm.org) instead of building
	  host-llvm, host-clang and host-libclc from source.

	  Requires llvm-22, llvm-22-dev, clang-22, clang-tools-22,
	  libllvm22, libclang1-22, libclang-cpp22, libclang-common-22-dev,
	  libclang-22-dev and libclc-22-dev to be installed in the
	  container image.

config BR2_PACKAGE_PROVIDES_HOST_LLVM
	string
	default "host-llvm-system" if BR2_PACKAGE_HOST_LLVM_SYSTEM

config BR2_PACKAGE_PROVIDES_HOST_CLANG
	string
	default "host-llvm-system" if BR2_PACKAGE_HOST_LLVM_SYSTEM

config BR2_PACKAGE_PROVIDES_HOST_LIBCLC
	string
	default "host-llvm-system" if BR2_PACKAGE_HOST_LLVM_SYSTEM
