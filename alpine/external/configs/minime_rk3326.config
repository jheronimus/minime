BR2_cortex_a35=y
BR2_GLOBAL_PATCH_DIR="$(BR2_EXTERNAL_MINIME_PATH)/board/rk3326/patches"
BR2_ROOTFS_POST_SCRIPT_ARGS="-c $(BR2_EXTERNAL_MINIME_PATH)/board/rk3326/genimage.cfg"
BR2_LINUX_KERNEL_CONFIG_FRAGMENT_FILES="$(BR2_EXTERNAL_MINIME_PATH)/board/rk3326/tiny-rk3326.config $(BR2_EXTERNAL_MINIME_PATH)/board/rk3326/tiny-dongles.config"
BR2_LINUX_KERNEL_INTREE_DTS_NAME="rockchip/rk3326-anbernic-rg351p rockchip/rk3326-anbernic-rg351m rockchip/rk3326-anbernic-rg351v rockchip/rk3326-anbernic-rg351mp"

BR2_TARGET_ARM_TRUSTED_FIRMWARE=y
BR2_TARGET_ARM_TRUSTED_FIRMWARE_CUSTOM_VERSION=y
BR2_TARGET_ARM_TRUSTED_FIRMWARE_CUSTOM_VERSION_VALUE="v2.15.0"
BR2_TARGET_ARM_TRUSTED_FIRMWARE_PLATFORM="px30"
BR2_TARGET_ARM_TRUSTED_FIRMWARE_IMAGES="bl31/bl31.elf"

BR2_TARGET_UBOOT_BOARD_DEFCONFIG="odroid-go2"
BR2_TARGET_UBOOT_CONFIG_FRAGMENT_FILES="$(BR2_EXTERNAL_MINIME_PATH)/board/rk3326/uboot.config"
BR2_TARGET_UBOOT_NEEDS_ATF_BL31=y
BR2_TARGET_UBOOT_NEEDS_ATF_BL31_ELF=y
BR2_TARGET_UBOOT_NEEDS_PYLIBFDT=y
BR2_TARGET_UBOOT_USE_BINMAN=y
BR2_TARGET_UBOOT_FORMAT_ITB=y

BR2_PACKAGE_LIBMALI=y
BR2_PACKAGE_LIBMALI_GPU_BIFROST_G31=y
BR2_PACKAGE_MALI_KBASE=y
BR2_PACKAGE_DRKHRSE_MIYOO_BEZELS=y
BR2_PACKAGE_RETROARCH_CORES=y
BR2_DEFCONFIG="$(BR2_EXTERNAL_MINIME_PATH)/configs/minime_rk3326_defconfig"
