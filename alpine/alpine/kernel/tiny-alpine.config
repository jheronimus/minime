# Minime Alpine kernel config delta.
#
# This fragment is merged AFTER tiny-base.config + tiny-<board>.config and
# BEFORE olddefconfig, so anything set here overrides both.  Build order
# (per alpine/aports/tinykernel/APKBUILD):
#
#   tiny-base.config -> tiny-<board>.config -> tiny-alpine.config -> olddefconfig
#
# Items in this file are Alpine-only deltas:
#   1. Panfrost + DRM scheduler for the Alpine userspace (Mesa + libdrm).
#   2. Failure guards:  any Mali (proprietary) option that would conflict
#      with Panfrost or that this distro does not ship is explicitly
#      disabled; `merge_config.sh` will fail the build if they reappear.
#
# All other kernel options (CPU, filesystems, networking, audio, display,
# touch, battery) are inherited from tiny-base.config + tiny-<board>.config
# so this fragment stays small and audit-friendly.

# ── Mesa Panfrost (Alpine GLES provider) ─────────────────────────────────
CONFIG_DRM_PANFROST=y
CONFIG_DRM_PANFROST_PERFMON=y

# ── DRM scheduler (required by Panfrost's GPU scheduling) ───────────────
CONFIG_DRM_SCHED=y

# ── Mali (proprietary) intentionally disabled ────────────────────────────
# CONFIG_MALI_KBASE is not set
# CONFIG_MALI_MIDGARD is not set
# CONFIG_MALI_BIFROST is not set
# CONFIG_MALI_PLATFORM_DEVICETREE is not set
# CONFIG_MALI_PLATFORM_NAME is not set
# CONFIG_MALI_BACKEND is not set
# CONFIG_MALI_REAL_HW is not set
# CONFIG_MALI_DEVFREQ is not set
# CONFIG_MALI_SHARED_INTERRUPTS is not set

# ── Panfrost is incompatible with CONFIG_MMU_NOTIFIER + custom notifier
#    drivers; the default upstream behavior is fine, so no extra # is set.
#    See drivers/gpu/drm/panfrost/panfrost_mmu.c.

# ── Hardening equivalent to Buildroot's CONFIG_CC_OPTIMIZE_FOR_SIZE ─────
# tiny-base.config already enables it; nothing to override here.

# ── Build reproducibility ───────────────────────────────────────────────
# The kernel build stamps need stable inputs: keep the local version empty
# and rely on KERNELRELEASE for tags.
CONFIG_LOCALVERSION=""
# CONFIG_LOCALVERSION_AUTO is not set
