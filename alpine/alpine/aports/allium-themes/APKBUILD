#!/bin/bash
# shellcheck shell=bash disable=SC3043,SC2154
# abuild framework sets srcdir/builddir/pkgdir in the build env.
# Maintainer: Minime <maintainers@minime-os.local>
pkgname=allium-themes
pkgver=1.0.0
pkgrel=0
pkgdesc="Allium themes (Rust asset bundle) for the Minime Alpine build"
url="https://github.com/goweiwen/Allium-Themes"
arch="aarch64"
license="MIT"
options="!strip !check"
source=""
export ALLIUM_THEMES_VERSION=a77abc867d6f4e836b186e34944b9b862b8ed3dd

build() {
	local workdir="$srcdir/build"
	mkdir -p "$workdir"
	cd "$workdir" || return 1

	if [ ! -d allium-themes ]; then
		git clone --no-checkout \
			https://github.com/goweiwen/Allium-Themes.git allium-themes
		(cd allium-themes && git checkout "${ALLIUM_THEMES_VERSION}")
	fi
}

package() {
	# Themes are dropped at /alpine-output/boot/ui/.ui/themes by the
	# Alpine build pipeline.  Stamping this APK lets the world list
	# pull the dependency in even when the actual asset copy is a
	# pipeline step.
	install -Dm644 /dev/null "$pkgdir/var/lib/minime/allium-themes.stamp"
}
