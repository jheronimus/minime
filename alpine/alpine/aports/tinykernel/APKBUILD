#!/bin/bash
# shellcheck shell=bash disable=SC3043,SC2154
# abuild framework sets srcdir/builddir/pkgdir in the build env.
# Maintainer: Minime <maintainers@minime-os.local>
pkgname=tinykernel
pkgver=7.0.10
pkgrel=0
pkgdesc="Minime minimal Linux kernel + DTBs for Alpine"
url="https://github.com/gregkh/linux"
arch="aarch64"
license="GPL-2.0-only"
options="!strip !check"
makedepends="
	bash
	bc
	bison
	flex
	gcc-aarch64
	binutils-aarch64
	linux-headers
	ncurses-dev
	openssl-dev
	perl
	python3
"

# Direct upstream tarball URL so the build is reproducible without aports sync.
# If you need the in-progress stable branch, switch to git://.
source="
	https://cdn.kernel.org/pub/linux/kernel/v${pkgver%%.*}.x/linux-${pkgver}.tar.xz
"
sha512sums="6f04fa9ced78f2e7a41dfae7f707f540e7cc6dcd4d3847f0d28df58b2d18a8edb75f98c674ba935538897e89864a06681f4cd56b91f3ea3e1b7f04096cb796e7  linux-7.0.10.tar.xz"

: "${DTB_BOARD:=rk3566}"
[ "$DTB_BOARD" = "rk3566" ] || { echo "unsupported DTB_BOARD=$DTB_BOARD"; exit 1; }
_dtbs="
	rockchip/rk3566-anbernic-rg-arc-d
	rockchip/rk3566-anbernic-rg-arc-s
	rockchip/rk3566-anbernic-rg353p
	rockchip/rk3566-anbernic-rg353ps
	rockchip/rk3566-anbernic-rg353v
	rockchip/rk3566-anbernic-rg353vs
	rockchip/rk3566-anbernic-rg503
	rockchip/rk3568-anbernic-rg-ds
"

build() {
	local src="$srcdir/linux-$pkgver"
	cd "$src" || return 1

	# 1. Apply Minime's kernel patch series.
	local patch_dir="/workspace/alpine/board/${DTB_BOARD}/patches/linux"
	if [ -d "$patch_dir" ]; then
		for p in "$patch_dir"/*.patch; do
			[ -f "$p" ] || continue
			msg "Applying $p"
			patch -p1 -N < "$p" || return 1
		done
	fi

	# 2. Merge kernel config:
	#    tiny-base.config -> tiny-<board>.config -> tiny-alpine.config -> olddefconfig
	local cfg_src="/workspace/alpine"
	cat > .config <<-EOF
		# merged by APKBUILD build()
		# tiny-base.config first
	EOF
	cat "$cfg_src/board/common/tiny-base.config" >> .config
	cat "$cfg_src/board/${DTB_BOARD}/tiny-${DTB_BOARD}.config" >> .config
	cat "$cfg_src/kernel/tiny-alpine.config" >> .config

	# 3. Resolve new options and surface any unresolved ones.
	make ARCH=arm64 CROSS_COMPILE=aarch64-alpine-linux-musl- olddefconfig

	# 4. Hard guard: CONFIG_DRM_PANFROST must be present, CONFIG_MALI_KBASE
	#    must not.  A future patch series that re-enables the proprietary
	#    Mali driver pair needs explicit opt-in, not a silent regression.
	grep -q "^CONFIG_DRM_PANFROST=y" .config \
		|| { echo "FATAL: CONFIG_DRM_PANFROST=y missing after olddefconfig"; return 1; }
	if grep -q "^CONFIG_MALI_KBASE=y\|^CONFIG_MALI_MIDGARD=y\|^CONFIG_MALI_BIFROST=y" .config; then
		echo "FATAL: proprietary Mali driver re-enabled by olddefconfig"; return 1
	fi

	# 5. Build kernel + DTBs + modules.
	make ARCH=arm64 CROSS_COMPILE=aarch64-alpine-linux-musl- -j"$JOBS" Image modules dtbs
}

package() {
	local src="$srcdir/linux-$pkgver"
	cd "$src" || return 1

	# We do not install tinykernel into the rootfs; the Alpine build
	# script copies Image + dtbs + modules to /alpine-output/boot/ for
	# post-image.sh to consume.  abuild still needs a "package" function
	# to succeed, so emit a tiny stamp APK with the .config + patches.
	install -Dm644 .config "$pkgdir/var/lib/minime/tinykernel.config"
	install -Dm644 arch/arm64/boot/Image "$pkgdir/var/lib/minime/tinykernel.Image"
	for dtb in $_dtbs; do
		local out="$pkgdir/var/lib/minime/dtbs/${dtb##*/}.dtb"
		install -Dm644 "arch/arm64/boot/dts/${dtb}.dtb" "$out"
	done

	# Modules go to /alpine-output/boot/modules, not into the rootfs.
	mkdir -p /alpine-output/boot/modules
	make ARCH=arm64 CROSS_COMPILE=aarch64-alpine-linux-musl- \
		INSTALL_MOD_PATH=/alpine-output/boot/modules modules_install
	rm -f /alpine-output/boot/modules/lib/modules/*/build /alpine-output/boot/modules/lib/modules/*/source
}

# Staging hook: build_tinykernel() in scripts/build.sh runs after abuild
# to pick up /alpine-output/boot/Image + DTBs.  abuild's "rootpkg" target
# produces the .apk listed above.
