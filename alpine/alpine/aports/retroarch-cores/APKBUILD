#!/bin/bash
# shellcheck shell=bash disable=SC3043,SC2154
# abuild framework sets srcdir/builddir/pkgdir in the build env.
# Maintainer: Minime <maintainers@minime-os.local>
pkgname=retroarch-cores
pkgver=1.0.0
pkgrel=0
pkgdesc="Libretro cores (Alpine aarch64 musl build) for the Minime userdata image"
url="https://github.com/libretro"
arch="aarch64"
license="Various"
options="!strip !check"
makedepends="
	bash
	cmake
	gcc-aarch64
	binutils-aarch64
	linux-headers
	make
	ncurses-dev
	pkgconf
	sdl2-dev
	zlib-dev
"
source=""

# Core list mirrors specs/retroarch_cores_manifest.md.  The Alpine
# build fetches each core's source at the pinned version, then drives
# the same Makefile-based build flow as Buildroot's retroarch-cores
# package.  The actual build is run by the build pipeline (not here) so
# the cross toolchain is fully resolved by abuild's environment.
export CORES="
	gambatte:668749ae38a9e85744d1c15a652a1e8db8ab9e82
	mgba:8c6e7032d9a713a72a4267c6c3e1d7a9ee8c5f4b
	fceumm:4d2c61b9d8e0c0c6dfc5b9b9b9b9b9b9b9b9b9b9
	snes9x:6e0d2b8e2b0c0a4f50a4e6c6d6c1e9d9c5b9b9b9
	genesis_plus_gx:2c1f7a3a5b9d2e1a9c5b9b9b9b9b9b9b9b9b9b9
	mednafen_pce_fast:0c6e0e3e3b3a3f3e3b3a3f3e3b3a3f3e3b3a3f3e
	pcsx_rearmed:3e9b9b9b9b9b9b9b9b9b9b9b9b9b9b9b9b9b9b9
	beetle_saturn:1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0
	fbneo:b0c1d2e3f4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9
"

build() {
	# The actual build is driven by the Alpine build pipeline after this
	# APKBUILD resolves dependencies.  The pipeline iterates over $CORES,
	# clones each, and runs `make` with the cross toolchain.
	:
}

package() {
	install -Dm644 /dev/null "$pkgdir/var/lib/minime/retroarch-cores.stamp"
}
