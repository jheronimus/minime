BOOTARGS="console=ttyS0,115200 console=tty1 root=/dev/ram0 rdinit=/init rootwait pm_async=off ignore_loglevel loglevel=7 printk.devkmsg=on consoleblank=0 vt.global_cursor_default=0 rtw88_core.disable_lps_deep=Y cma=128M drm_kms_helper.drm_fbdev_overalloc=200"
DEFAULT_DEVICE="sun50i-h700-anbernic-rg35xx-sp.dtb"
EXTRA_ENV="setenv ramdisk_addr_r 0x46000000"
