# ── SoC Architecture & Core Infrastructure ────────────────────────────────────
# Allwinner sunxi platform support, DMA controller, IOMMU, thermal sensor,
# EFUSE memory map, and PRCM power domain controller for H700 SoC.
CONFIG_ARCH_SUNXI=y
CONFIG_DMA_SUN6I=y
CONFIG_FIRMWARE_MEMMAP=y
CONFIG_NVMEM_SUNXI_SID=y
CONFIG_SUN50I_H6_PRCM_PPU=y
CONFIG_SUN50I_IOMMU=y
CONFIG_SUN8I_THERMAL=y

# ── Power Management & AXP PMIC ───────────────────────────────────────────────
# AXP209/AXP717 PMIC core driver over I2C, regulator control, battery charger,
# power key input event handling, and ADC hardware monitoring.
CONFIG_ARM_ALLWINNER_SUN50I_CPUFREQ_NVMEM=y
CONFIG_AXP20X_ADC=y
CONFIG_AXP20X_POWER=y
CONFIG_BATTERY_AXP20X=y
CONFIG_INPUT_AXP20X_PEK=y
CONFIG_MFD_AXP20X_I2C=y
CONFIG_REGULATOR_AXP20X=y

# ── Display, Backlight & Audio ────────────────────────────────────────────────
# Allwinner Display Engine 2.0 (sun4i-drm), MIPI-DSI panel interface,
# PWM backlight controllers, and sun4i SoC audio codec driver.
CONFIG_DRM_PANEL_MIPI=y
CONFIG_DRM_SUN4I=y
CONFIG_PWM_SUN20I=y
CONFIG_PWM_SUN4I=y
CONFIG_SND_SUN4I_CODEC=y

# ── Analog Input & GPIO Multiplexing ──────────────────────────────────────────
# Analog joystick support driven via IIO ADC and GPIO multiplexer.
CONFIG_IIO_MUX=y
CONFIG_JOYSTICK_ADC=y
CONFIG_MULTIPLEXER=y
CONFIG_MUX_GPIO=y

# ── Storage & SD/eMMC Controllers ─────────────────────────────────────────────
# Allwinner sunxi SD/MMC host controller (MMC core + block device in base).
CONFIG_MMC_SUNXI=y

# ── Peripherals, Wireless & Firmware ──────────────────────────────────────────
# Marvell I2C, USB PHY, Realtek Bluetooth UART, RTC clock, and builtin firmware
# blobs required for H700 handheld board boot (RTW88 Wi-Fi in base).
CONFIG_BT_HCIUART_RTL=y
CONFIG_EXTRA_FIRMWARE="panels/anbernic,rg35xx-plus-panel.panel rtl_bt/rtl8821cs_fw.bin rtl_bt/rtl8821cs_config.bin rtw88/rtw8821c_fw.bin"
CONFIG_EXTRA_FIRMWARE_DIR="__MINIME_BOARD_FIRMWARE_DIR__"
CONFIG_I2C_MV64XXX=y
CONFIG_PHY_SUN4I_USB=y
CONFIG_RTC_DRV_SUN6I=y
