# ── SoC Architecture & Core Drivers ───────────────────────────────────────────
# Rockchip platform support, thermal management, USB2 PHY, MIPI DSI PHY,
# and PWM controller for RK3326 handheld devices.
CONFIG_ARCH_ROCKCHIP=y
CONFIG_PHY_ROCKCHIP_INNO_DSIDPHY=y
CONFIG_PHY_ROCKCHIP_INNO_USB2=y
CONFIG_PWM_ROCKCHIP=y
CONFIG_ARM_PSCI_CPUIDLE=y
CONFIG_ROCKCHIP_THERMAL=y

# ── Storage & SD/eMMC Controllers ─────────────────────────────────────────────
# DesignWare MMC host controller and Rockchip glue layer
# (MMC core + block device in base).
CONFIG_MMC_DW=y
CONFIG_MMC_DW_PLTFM=y
CONFIG_MMC_DW_ROCKCHIP=y

# ── Power Management & PMIC ───────────────────────────────────────────────────
# RK817/RK808 PMIC core driver over I2C, regulators, and battery charger.
CONFIG_CHARGER_RK817=y
CONFIG_MFD_RK8XX=y
CONFIG_MFD_RK8XX_I2C=y
CONFIG_REGULATOR_RK808=y

# ── Display Controller & Panel Drivers ────────────────────────────────────────
# Rockchip DRM subsystem, Sitronix ST7703 DSI panel, simple panel support,
# Analogix DP bridge, DesignWare HDMI, and DesignWare MIPI DSI controllers.
CONFIG_DRM_PANEL_SIMPLE=y
CONFIG_DRM_PANEL_SITRONIX_ST7703=y
CONFIG_DRM_ROCKCHIP=y
CONFIG_ROCKCHIP_ANALOGIX_DP=y
CONFIG_ROCKCHIP_DW_HDMI=y
CONFIG_ROCKCHIP_DW_MIPI_DSI=y

# ── Input & Analog Controls ───────────────────────────────────────────────────
# Matrix keyboard input driver and ADC-based SAR button matrix controller.
CONFIG_INPUT_KEYBOARD=y
CONFIG_KEYBOARD_ADC=y
