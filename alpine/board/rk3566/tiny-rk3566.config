# ── SoC Architecture & Firmware Interfaces ────────────────────────────────────
# Rockchip RK3566 SoC architecture, GPT partition support, ARM SCMI protocol
# and power domain, IOMMU, power domain controller, IO domain voltage select,
# ARM PL330 DMA engine, and Rockchip OTP memory access.
CONFIG_ARCH_ROCKCHIP=y
CONFIG_ARM_SCMI_POWER_DOMAIN=y
CONFIG_ARM_SCMI_PROTOCOL=y
CONFIG_COMMON_CLK_SCMI=y
CONFIG_EFI_PARTITION=y
CONFIG_NVMEM_ROCKCHIP_OTP=y
CONFIG_PL330_DMA=y
CONFIG_ROCKCHIP_IODOMAIN=y
CONFIG_ROCKCHIP_IOMMU=y
CONFIG_ROCKCHIP_PM_DOMAINS=y

# ── CPU Performance & Cortex-A55 Errata ───────────────────────────────────────
# Cortex-A55 silicon errata workarounds, Hardware AF/DBM, Common Not Private
# translation tables, Activity Monitors Extension, multi-core scheduling,
# and governor configured for performance.
CONFIG_ARM64_AMU_EXTN=y
CONFIG_ARM64_CNP=y
CONFIG_ARM64_ERRATUM_1024718=y
CONFIG_ARM64_ERRATUM_1530923=y
CONFIG_ARM64_ERRATUM_2441007=y
CONFIG_ARM64_HW_AFDBM=y
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_SCHED_MC=y

# ── Storage & SD/eMMC Controllers ─────────────────────────────────────────────
# SDHCI controller, DesignWare eMMC/SD host interface, and Rockchip specific
# MMC glue logic (MMC core + block device in base).
CONFIG_MMC_DW=y
CONFIG_MMC_DW_PLTFM=y
CONFIG_MMC_DW_ROCKCHIP=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_OF_DWCMSHC=y
CONFIG_MMC_SDHCI_PLTFM=y

# ── Power Management, PMIC & RTC ──────────────────────────────────────────────
# RK817/RK808 PMIC core, I2C interface, clock output, pin control, FAN53555
# buck regulator, power off/reset via GPIO, battery charger, and RTC driver.
CONFIG_CHARGER_RK817=y
CONFIG_COMMON_CLK_RK808=y
CONFIG_MFD_RK8XX=y
CONFIG_MFD_RK8XX_I2C=y
CONFIG_PINCTRL_RK805=y
CONFIG_POWER_RESET_GPIO=y
CONFIG_POWER_RESET_GPIO_RESTART=y
CONFIG_REGULATOR_FAN53555=y
CONFIG_REGULATOR_RK808=y
CONFIG_RTC_DRV_RK808=y
CONFIG_RTC_HCTOSYS=y
CONFIG_RTC_SYSTOHC=y

# ── Display Controller & Panel Drivers ────────────────────────────────────────
# Rockchip VOP2 display controller, console rotation, panel drivers (ST7701,
# ST7703, simple panel), DesignWare HDMI, and DesignWare MIPI DSI interfaces.
CONFIG_DRM_PANEL_SIMPLE=y
CONFIG_DRM_PANEL_SITRONIX_ST7701=y
CONFIG_DRM_PANEL_SITRONIX_ST7703=y
CONFIG_DRM_ROCKCHIP=y
CONFIG_FRAMEBUFFER_CONSOLE_ROTATION=y
CONFIG_ROCKCHIP_DW_HDMI=y
CONFIG_ROCKCHIP_DW_MIPI_DSI=y
CONFIG_ROCKCHIP_VOP2=y

# ── Sound & Audio Subsystem ───────────────────────────────────────────────────
# Rockchip I2S/TDM audio controller, RK817 audio codec, simple audio card,
# and external amplifier driver for RK3566 handheld speaker output.
CONFIG_SND_SIMPLE_CARD=y
CONFIG_SND_SOC_RK817=y
CONFIG_SND_SOC_ROCKCHIP_I2S_TDM=y
CONFIG_SND_SOC_SIMPLE_AMPLIFIER=y

# ── Peripherals, Input & Touchscreen ──────────────────────────────────────────
# Rockchip I2C, USB2 PHY, DSI PHY, Naneng Combo PHY, DWC3 USB controller,
# thermal sensor, PWM, SARADC, matrix keyboard, Goodix touch, and watchdog.
CONFIG_DW_WATCHDOG=y
CONFIG_HWMON=y
CONFIG_I2C_RK3X=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_INPUT_TOUCHSCREEN=y
CONFIG_KEYBOARD_ADC=y
CONFIG_PHY_ROCKCHIP_INNO_DSIDPHY=y
CONFIG_PHY_ROCKCHIP_INNO_USB2=y
CONFIG_PHY_ROCKCHIP_NANENG_COMBO_PHY=y
CONFIG_PWM_ROCKCHIP=y
CONFIG_ROCKCHIP_SARADC=y
CONFIG_ROCKCHIP_THERMAL=y
CONFIG_TOUCHSCREEN_GOODIX=y
CONFIG_USB_DWC3=y
CONFIG_USB_DWC3_GENERIC_PLAT=y
CONFIG_USB_DWC3_OF_SIMPLE=y
CONFIG_WATCHDOG=y

# ── Wireless Connectivity & Firmware ──────────────────────────────────────────
# Realtek Bluetooth UART interface, rtw88 Wi-Fi driver, and builtin firmware.
CONFIG_BT_HCIUART_RTL=y
CONFIG_EXTRA_FIRMWARE="rtl_bt/rtl8821cs_fw.bin rtl_bt/rtl8821cs_config.bin rtw88/rtw8821c_fw.bin"
CONFIG_EXTRA_FIRMWARE_DIR="__MINIME_COMMON_FIRMWARE_DIR__"
CONFIG_RTW88=y
CONFIG_RTW88_8821CS=y

# ── Diagnostics & Debugging ───────────────────────────────────────────────────
# Kernel config in /proc, hung task detector, pstore memory log capture,
# and SysRq panic trigger for crash recovery testing.
CONFIG_DETECT_HUNG_TASK=y
CONFIG_IKCONFIG=y
CONFIG_IKCONFIG_PROC=y
CONFIG_MAGIC_SYSRQ=y
CONFIG_PSTORE=y
CONFIG_PSTORE_COMPRESS=y
CONFIG_PSTORE_CONSOLE=y
CONFIG_PSTORE_RAM=y
