# ── Mesa Panfrost GPU Driver & Dependencies ───────────────────────────────────
# Enables open-source Panfrost DRM driver for Mali GPU alongside required
# memory compaction, IOMMU support, and DRM GPU scheduler.
CONFIG_COMPACTION=y
CONFIG_DRM_PANFROST=y
CONFIG_DRM_PANFROST_PERFMON=y
CONFIG_DRM_SCHED=y
CONFIG_IOMMU_SUPPORT=y

# ── Build Reproducibility ─────────────────────────────────────────────────────
# Keep local kernel version string empty for stable build outputs.
CONFIG_LOCALVERSION=""

# ── Trimmings ─────────────────────────────────────────────────────────────────
# CONFIG_LOCALVERSION_AUTO is not set   # prevent git commit hash in version tag
# CONFIG_MALI_BACKEND is not set        # proprietary Mali driver not used
# CONFIG_MALI_BIFROST is not set        # proprietary Mali driver not used
# CONFIG_MALI_DEVFREQ is not set        # proprietary Mali driver not used
# CONFIG_MALI_KBASE is not set          # proprietary Mali driver not used
# CONFIG_MALI_MIDGARD is not set        # proprietary Mali driver not used
# CONFIG_MALI_PLATFORM_DEVICETREE is not set # proprietary Mali DT unused
# CONFIG_MALI_PLATFORM_NAME is not set  # proprietary Mali driver not used
# CONFIG_MALI_REAL_HW is not set        # proprietary Mali driver not used
# CONFIG_MALI_SHARED_INTERRUPTS is not set # proprietary Mali driver not used
