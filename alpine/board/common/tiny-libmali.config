# ── Proprietary ARM Mali (libmali) Kernel Config Delta ────────────────────────
# Out-of-tree mali-kbase module is built separately by Buildroot. No in-tree
# =y options are set here. Panfrost and compaction are explicitly disabled.

# ── Trimmings ─────────────────────────────────────────────────────────────────
# CONFIG_COMPACTION is not set        # mali-kbase hangs with compaction enabled
# CONFIG_DRM_PANFROST is not set        # proprietary libmali replaces panfrost
