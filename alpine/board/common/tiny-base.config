# ── System Core & Process Management ──────────────────────────────────────────
# POSIX IPC, message queues, NO_HZ_IDLE tickless timer, high resolution timers,
# preemptive scheduling, pressure stall info (PSI), task UCLAMP,
# cgroups, memory cgroups, namespaces, and freezer cgroups.
CONFIG_CGROUPS=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_SCHED=y
CONFIG_EXPERT=y
CONFIG_HIGH_RES_TIMERS=y
CONFIG_LOG_BUF_SHIFT=14
CONFIG_MEMCG=y
CONFIG_NAMESPACES=y
CONFIG_NO_HZ_IDLE=y
CONFIG_POSIX_MQUEUE=y
CONFIG_PREEMPT=y
CONFIG_PSI=y
CONFIG_SYSVIPC=y
CONFIG_UCLAMP_TASK=y

# ── Architecture & Boot Initramfs ─────────────────────────────────────────────
# Configures ARM64 48-bit Virtual Address space, 4 CPU cores maximum, 1000 Hz
# timer tick rate, size optimization, initrd loop mount, and gzip RAM disk.
CONFIG_ARM64_VA_BITS_48=y
CONFIG_BLK_DEV_INITRD=y
CONFIG_BLK_DEV_LOOP=y
CONFIG_CC_OPTIMIZE_FOR_SIZE=y
CONFIG_HZ_1000=y
CONFIG_NR_CPUS=4
CONFIG_RD_GZIP=y

# ── CPU Frequency, Idle Governors & Power Management ──────────────────────────
# Enables TEO CPU idle governor for tickless workloads, power-efficient
# workqueues, PSCI cpuidle, frequency scaling stats, schedutil/ondemand
# governors, cpufreq-dt driver, devfreq thermal control, and system suspend.
CONFIG_ARM_PSCI_FW=y
CONFIG_CPUFREQ_DT=y
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_GOV_ONDEMAND=y
CONFIG_CPU_FREQ_GOV_POWERSAVE=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
CONFIG_CPU_FREQ_STAT=y
CONFIG_CPU_FREQ_THERMAL=y
CONFIG_CPU_IDLE=y
CONFIG_CPU_IDLE_GOV_TEO=y
CONFIG_CPU_THERMAL=y
CONFIG_DEVFREQ_EVENT_ROCKCHIP_DFI=y
CONFIG_DEVFREQ_GOV_SIMPLE_ONDEMAND=y
CONFIG_DEVFREQ_THERMAL=y
CONFIG_PM=y
CONFIG_PM_DEVFREQ=y
CONFIG_PM_DEVFREQ_EVENT=y
CONFIG_PM_SLEEP=y
CONFIG_SUSPEND=y
CONFIG_SUSPEND_FREEZER=y
CONFIG_THERMAL=y
CONFIG_WQ_POWER_EFFICIENT_DEFAULT=y

# ── Memory Management, Swap & ZRAM ────────────────────────────────────────────
# In-memory compressed swap (zram using LZ4 compression), SLUB tiny allocator,
# Contiguous Memory Allocator (64MB, 7 areas), zsmalloc, and Multi-Gen LRU.
CONFIG_CMA=y
CONFIG_CMA_AREAS=7
CONFIG_CMA_SIZE_MBYTES=64
CONFIG_DMA_CMA=y
CONFIG_LRU_GEN=y
CONFIG_LRU_GEN_ENABLED=y
CONFIG_SLUB_TINY=y
CONFIG_SWAP=y
CONFIG_ZRAM=y
CONFIG_ZRAM_BACKEND_LZ4=y
CONFIG_ZRAM_DEF_COMP_LZ4=y
CONFIG_ZSMALLOC=y

# ── Networking, Bluetooth & Wireless Core ─────────────────────────────────────
# Network stack (IPv4, UNIX sockets, Packet sockets, SYN cookies), Bluetooth
# subsystem (RFCOMM, HIDP, HCI UART H4), mac80211, cfg80211, and RFKILL.
CONFIG_BT=y
CONFIG_BT_HCIUART=y
CONFIG_BT_HCIUART_H4=y
CONFIG_BT_HIDP=y
CONFIG_BT_RFCOMM=y
CONFIG_CFG80211=y
CONFIG_INET=y
CONFIG_IP_MULTICAST=y
CONFIG_MAC80211=y
CONFIG_NET=y
CONFIG_NETDEVICES=y
CONFIG_PACKET=y
CONFIG_RFKILL=y
CONFIG_RFKILL_INPUT=y
CONFIG_SYN_COOKIES=y
CONFIG_UNIX=y

# ── Device Drivers, Bus & System Infrastructure ───────────────────────────────
# Devtmpfs auto-mount, uevent mdev helper, compressed firmware loader,
# serial 8250 console & DesignWare UART, SPI bus & GPIO, MFD syscon, regulators,
# IOMMU LPAE page tables, DMABUF heaps, DMA devices, Extcon, IIO, PWM,
# NVMEM, LEDs class & triggers, and PCF8563 RTC driver.
CONFIG_BACKLIGHT_CLASS_DEVICE=y
CONFIG_BACKLIGHT_PWM=y
CONFIG_CONSOLE_LOGLEVEL_DEFAULT=4
CONFIG_DEVPTS_FS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_DMABUF_HEAPS=y
CONFIG_DMABUF_HEAPS_CMA=y
CONFIG_DMABUF_HEAPS_SYSTEM=y
CONFIG_DMADEVICES=y
CONFIG_DRM=y
CONFIG_DRM_DW_HDMI_I2S_AUDIO=y
CONFIG_EXTCON=y
CONFIG_FB=y
CONFIG_FRAMEBUFFER_CONSOLE_DEFERRED_TAKEOVER=y
CONFIG_FW_LOADER_COMPRESS=y
CONFIG_IIO=y
CONFIG_IOMMU_IO_PGTABLE_LPAE=y
CONFIG_LEDS_CLASS=y
CONFIG_LEDS_CLASS_MULTICOLOR=y
CONFIG_LEDS_GPIO=y
CONFIG_LEDS_TRIGGERS=y
CONFIG_LEDS_TRIGGER_DEFAULT_ON=y
CONFIG_LEDS_TRIGGER_HEARTBEAT=y
CONFIG_LEDS_TRIGGER_TIMER=y
CONFIG_MFD_SYSCON=y
CONFIG_MMC=y
CONFIG_MMC_BLOCK=y
CONFIG_MMC_BLOCK_MINORS=32
CONFIG_NEW_LEDS=y
CONFIG_NVMEM=y
CONFIG_PWM=y
CONFIG_REGULATOR=y
CONFIG_REGULATOR_FIXED_VOLTAGE=y
CONFIG_RTC_CLASS=y
CONFIG_RTC_DRV_PCF8563=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_DW=y
CONFIG_SERIAL_DEV_BUS=y
CONFIG_SERIAL_OF_PLATFORM=y
CONFIG_SPI=y
CONFIG_SPI_GPIO=y
CONFIG_SPI_MEM=y
CONFIG_UEVENT_HELPER=y
CONFIG_UEVENT_HELPER_PATH="/sbin/mdev"
CONFIG_UNIX98_PTYS=y

# ── Input Subsystem & Gamepad Controllers ─────────────────────────────────────
# Event device node interface, memoryless force feedback, GPIO keyboard buttons,
# joystick subsystem, xpad Xbox controller driver, uinput, uhid, and HID drivers
# for Nintendo, PlayStation, and Sony controllers.
CONFIG_HID_NINTENDO=y
CONFIG_HID_PLAYSTATION=y
CONFIG_HID_SONY=y
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_FF_MEMLESS=y
CONFIG_INPUT_JOYSTICK=y
CONFIG_INPUT_MISC=y
CONFIG_INPUT_UINPUT=y
CONFIG_JOYSTICK_XPAD=y
CONFIG_KEYBOARD_GPIO=y
CONFIG_UHID=y

# ── USB Host & Sound Subsystem ────────────────────────────────────────────────
# USB OTG, EHCI, OHCI platform controllers, MUSB HDRC controller,
# ALSA sound subsystem, HRTIMER timer backend, and SoC audio framework.
CONFIG_SND=y
CONFIG_SND_HRTIMER=y
CONFIG_SND_SOC=y
CONFIG_SOUND=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_EHCI_HCD_PLATFORM=y
CONFIG_USB_MUSB_HDRC=y
CONFIG_USB_OHCI_HCD=y
CONFIG_USB_OHCI_HCD_PLATFORM=y
CONFIG_USB_OTG=y

# ── Filesystems, NLS & Crypto ─────────────────────────────────────────────────
# Ext4, F2FS with compression, OverlayFS, VFAT, TmpFS with ACL, EROFS with LZ4
# compression, UTF-8/CP437/ISO8859-1 character sets, binfmt_misc binary support,
# Diffie-Hellman keys, and Crypto API (DES, CBC, MD5, SHA1, CRC32C, LZ4, ZSTD).
CONFIG_BINFMT_MISC=y
CONFIG_CRYPTO_CBC=y
CONFIG_CRYPTO_CRC32C=y
CONFIG_CRYPTO_DES=y
CONFIG_CRYPTO_LZ4=y
CONFIG_CRYPTO_LZ4HC=y
CONFIG_CRYPTO_MD5=y
CONFIG_CRYPTO_SHA1=y
CONFIG_CRYPTO_USER_API_HASH=y
CONFIG_CRYPTO_USER_API_SKCIPHER=y
CONFIG_CRYPTO_ZSTD=y
CONFIG_EROFS_FS=y
CONFIG_EROFS_FS_ZIP=y
CONFIG_EXT4_FS=y
CONFIG_EXT4_FS_POSIX_ACL=y
CONFIG_F2FS_FS=y
CONFIG_F2FS_FS_COMPRESSION=y
CONFIG_KEY_DH_OPERATIONS=y
CONFIG_LZ4_DECOMPRESS=y
CONFIG_NLS_CODEPAGE_437=y
CONFIG_NLS_DEFAULT="utf8"
CONFIG_NLS_ISO8859_1=y
CONFIG_NLS_UTF8=y
CONFIG_OVERLAY_FS=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_VFAT_FS=y

