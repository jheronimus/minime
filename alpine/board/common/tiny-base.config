# ── Wireless LAN (Realtek SDIO) ──────────────────────────────────────────────
# Built-in Realtek rtw88 Wi-Fi driver for SDIO-connected 802.11ac chips
# (8821CS, etc.) used across all boards.
CONFIG_WLAN_VENDOR_REALTEK=y
CONFIG_RTW88=y
CONFIG_RTW88_8821CS=y

# ── Firmware ──────────────────────────────────────────────────────────────────
# Builtin firmware blobs for Realtek Bluetooth and rtw88 Wi-Fi (SDIO 8821CS).
# Boards that need additional firmware (e.g. display panels) override this.
CONFIG_EXTRA_FIRMWARE="rtl_bt/rtl8821cs_fw.bin rtl_bt/rtl8821cs_config.bin rtw88/rtw8821c_fw.bin"
CONFIG_EXTRA_FIRMWARE_DIR="__MINIME_COMMON_FIRMWARE_DIR__"
