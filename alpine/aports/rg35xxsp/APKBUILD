pkgname=rg35xxsp
pkgver=0.1.0
pkgrel=10
pkgdesc="RG35xxSP board assets, overlays, and OpenRC wrappers for the SP image"
arch="aarch64"
url="https://github.com/sp-firmware/sp"
license="custom"
depends="openrc"
source=""
options="!check"
_repo_root="$startdir/../.."
_board_root="$_repo_root/board/rg35xxsp"

package() {
  install -D -m 0755 "$_board_root/overlay/etc/init.d/unblank" "$pkgdir/etc/init.d/unblank"
  install -D -m 0755 "$_board_root/overlay/etc/init.d/wifi" "$pkgdir/etc/init.d/wifi"
  install -D -m 0755 "$_board_root/overlay/etc/init.d/telnetd" "$pkgdir/etc/init.d/telnetd"
  install -D -m 0755 "$_board_root/overlay/usr/bin/autologin" "$pkgdir/usr/bin/autologin"
  install -D -m 0755 "$_board_root/overlay/etc/init.d/ftpd" "$pkgdir/etc/init.d/ftpd"
  install -D -m 0644 "$_board_root/firmware/rtl_bt/rtl8821cs_config.bin" "$pkgdir/lib/firmware/rtl_bt/rtl8821cs_config.bin"
}
