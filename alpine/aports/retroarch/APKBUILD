# shellcheck shell=sh disable=SC2034,SC2154,SC3043
# abuild framework sets srcdir/builddir/pkgdir in the build env.
# Maintainer: Minime <maintainers@minime-os.local>
pkgname=retroarch
pkgver=1.22.2
pkgrel=0
pkgdesc="RetroArch frontend (Alpine aarch64 musl build)"
url="https://github.com/libretro/RetroArch"
arch="aarch64"
license="GPL-3.0-or-later"
options="!strip !check"
makedepends="
	alsa-lib-dev
	bash
	binutils-aarch64
	gcc-aarch64
	libdrm-dev
	mesa-dev
	linux-headers
	make
	ncurses-dev
	pkgconf
	sdl2-dev
	zlib-dev
"
source="$pkgname-$pkgver.tar.gz::https://github.com/libretro/RetroArch/archive/v$pkgver.tar.gz"
sha512sums="59057d3fff3bec3bcb01143a270c3b9e74d148a2f1caa413d52f3533af94564576d2fce6f6273b5c79d11904ef670a6bf7c2c328fe3534a05d160e8a49b9daa1  retroarch-1.22.2.tar.gz"

build() {
	cd "$srcdir/RetroArch-$pkgver" || return 1
	./configure \
		--prefix=/usr \
		--sysconfdir=/etc \
		--disable-opengl \
		--enable-egl \
		--enable-opengles \
		--enable-kms \
		--disable-x11 \
		--disable-wayland \
		--enable-alsa \
		--disable-ffmpeg \
		--enable-zlib
	make
}

package() {
	cd "$srcdir/RetroArch-$pkgver" || return 1
	make DESTDIR="$pkgdir" install

	# Drop the canonical config where the Alpine build pipeline expects it.
	install -Dm644 /dev/null \
		"$pkgdir/etc/retroarch.cfg"

	rm -rf "${pkgdir:?}/usr/share"
}
