# shellcheck shell=sh disable=SC2034,SC2154,SC3043
# abuild framework sets srcdir/builddir/pkgdir in the build env.
# Maintainer: Minime <maintainers@minime-os.local>
pkgname=allium
pkgver=1.0.0
pkgrel=0
pkgdesc="Allium launcher frontend for Minime (prebuilt distribution)"
url="https://github.com/jheronimus/Allium"
arch="aarch64"
license="MIT"
options="!strip !check"
makedepends="curl unzip"
depends="!minui"
provides="minime-ui"

ALLIUM_DATE=20260720
ALLIUM_VERSION="v${ALLIUM_DATE}"
source="https://github.com/jheronimus/Allium/releases/download/${ALLIUM_VERSION}/allium-minime-aarch64.zip"
sha512sums="be037fe0dac532dfb0ddae9b2ea68436094b77020eceb34bef1630c2e2b7721a8b6c0c4f1bbb7b468f7dee1dcfefc7b9764342e8f505d548b564d66ba2e3b828  allium-minime-aarch64.zip"

build() {
	cd "$srcdir" || return 1
	unzip -o "allium-minime-aarch64.zip"
}

package() {
	# Stage the UI payload to /alpine-output/boot/ui for post-image.sh
	# to consume.  Allium expects .ui/ at SD card root.
	mkdir -p /alpine-output/boot/ui/.ui
	cp -a "$srcdir"/.ui/. /alpine-output/boot/ui/.ui/

	# Apps directory
	if [ -d "$srcdir"/apps ]; then
		mkdir -p /alpine-output/boot/ui/apps
		cp -a "$srcdir"/apps/. /alpine-output/boot/ui/apps/
	fi

	# .tmp_update (screenshot/say/show helpers)
	if [ -d "$srcdir"/.tmp_update ]; then
		mkdir -p /alpine-output/boot/ui/.tmp_update
		cp -a "$srcdir"/.tmp_update/. /alpine-output/boot/ui/.tmp_update/
	fi

	# RetroArch
	if [ -d "$srcdir"/RetroArch ]; then
		cp -a "$srcdir"/RetroArch /alpine-output/boot/ui/
	fi

	# Stamp for the Alpine rootfs
	install -dm755 "$pkgdir/var/lib/minime"
	install -Dm644 /dev/null "$pkgdir/var/lib/minime/allium.stamp"
}
