#!/bin/bash
# shellcheck shell=bash disable=SC3043,SC2154
# abuild framework sets srcdir/builddir/pkgdir in the build env.
# Maintainer: Minime <maintainers@minime-os.local>
pkgname=allium
pkgver=1.0.0
pkgrel=0
pkgdesc="Allium frontend (Rust) for Minime — Alpine aarch64 musl build"
url="https://github.com/jheronimus/Allium"
arch="aarch64"
license="MIT"
options="!strip !check"
makedepends="
	cargo
	clang-dev
	gcc-aarch64
	binutils-aarch64
	libretro-common
	linux-headers
	ncurses-dev
	openssl-dev
	rust
"
export ALLIUM_VERSION=3e2d6095817519437a4f7cf691806cc58a02af7c
source="allium-$ALLIUM_VERSION.tar.gz::https://github.com/jheronimus/Allium/archive/$ALLIUM_VERSION.tar.gz"

build() {
	# Allium needs LIBCLANG_PATH for bindgen, BINDGEN_EXTRA_CLANG_ARGS for
	# the cross-sysroot, and LIBRETRO_HEADER pointing at libretro-common's
	# installed libretro.h.  Alpine's `libretro-common` package provides
	# that header.
	export LIBCLANG_PATH=/usr/lib
	export LIBRETRO_HEADER=/usr/include/libretro.h
	export BINDGEN_EXTRA_CLANG_ARGS="--sysroot=/usr/aarch64-linux-musl -I/usr/aarch64-linux-musl/usr/include"
	export CARGO_TARGET_AARCH64_ALPINE_LINUX_MUSL_LINKER="aarch64-alpine-linux-musl-gcc"

	cd "$srcdir/allium-$ALLIUM_VERSION" || return 1
	cargo build --release --target aarch64-alpine-linux-musl --features minime
}

package() {
	local bindir="$pkgdir/var/lib/minime/bin"
	mkdir -p "$bindir"

	# Allium's runtime payload goes to /alpine-output/boot/ui (same as
	# Image assembly copies the staged UI payload. This APK only stamps the slot.
	install -Dm644 /dev/null "$pkgdir/var/lib/minime/allium.stamp"
}

sha512sums="d6d1395861fda05ae2629c5b30aa243027cc816a458050260c1d606b2b3a24685229f7f49c191a089bf6eba589aa5d081e9c71f3ca59e05b7b2afcfc1f99e49f  allium-3e2d6095817519437a4f7cf691806cc58a02af7c.tar.gz"
