# shellcheck shell=sh disable=SC2034,SC2154,SC3043
# abuild framework sets srcdir/builddir/pkgdir in the build env.
# Maintainer: Minime <maintainers@minime-os.local>
pkgname=minui
pkgver=20260720
pkgrel=0
pkgdesc="MinUI launcher frontend for Minime (prebuilt distribution)"
url="https://github.com/jheronimus/MinUI"
arch="aarch64"
license="MIT"
options="!strip !check"
makedepends="curl unzip"
depends="!allium"
provides="minime-ui"

MINUI_DOT=0
source="https://github.com/jheronimus/MinUI/releases/download/v${pkgver}/MinUI-${pkgver}-${MINUI_DOT}-base.zip
	https://github.com/jheronimus/MinUI/releases/download/v${pkgver}/MinUI-${pkgver}-${MINUI_DOT}-extras.zip"
sha512sums="54454dcce6f298fbaced2cba012eaa78f2f7d74207c6b34235be1ac729dca3de8575d6f146c1c7cea359a80b6597ff8463950d712863a4df9c587a94a7944d3a  MinUI-20260720-0-base.zip
b6183b816031d1a518c986cb2f41a2c7668f4888a909b3b4cb9d42b6c7014e51ad5519abd9bba6f97dacbc87a89b310551a0c49d6073f0a8407c00325704bb7c  MinUI-20260720-0-extras.zip"

build() {
	cd "$srcdir" || return 1
	unzip -o "MinUI-${pkgver}-${MINUI_DOT}-base.zip"
	unzip -o MinUI.zip
	unzip -o "MinUI-${pkgver}-${MINUI_DOT}-extras.zip"
}

package() {
	# Stage the UI payload to /alpine-output/boot/ui for post-image.sh
	# to consume.  The Alpine rootfs does not contain minui binaries;
	# they live on the SD card's FAT32 partition.
	# MinUI expects .system/minime/ at SD card root; post-image.sh copies
	# boot/ui/ → SD card root, so we stage under that prefix.
	mkdir -p /alpine-output/boot/ui/.system
	cp -a "$srcdir"/.system/. /alpine-output/boot/ui/.system/

	# Strip .elf extensions (MinUI convention; Minime expects bare names)
	for f in /alpine-output/boot/ui/.system/minime/bin/*.elf; do
		[ -f "$f" ] && mv -f "$f" "${f%.elf}"
	done

	# Install extras (emulator paks + tools) to SD card root
	if [ -d "$srcdir"/Emus ]; then
		cp -a "$srcdir"/Emus /alpine-output/boot/ui/
	fi
	if [ -d "$srcdir"/Tools ]; then
		cp -a "$srcdir"/Tools /alpine-output/boot/ui/
	fi

	# Stamp for the Alpine rootfs
	install -dm755 "$pkgdir/var/lib/minime"
	install -Dm644 /dev/null "$pkgdir/var/lib/minime/minui.stamp"
}
