# shellcheck shell=sh disable=SC2034,SC2154,SC3043
# abuild framework sets srcdir/builddir/pkgdir in the build env.
# Maintainer: Minime <maintainers@minime-os.local>
pkgname=minui
pkgver=1.0.0
pkgrel=0
pkgdesc="MinUI launcher frontend for Minime (prebuilt distribution)"
url="https://github.com/jheronimus/MinUI"
arch="aarch64"
license="MIT"
options="!strip !check"
makedepends="curl unzip"

MINUI_DATE=20260720
MINUI_DOT=0
MINUI_VERSION="v${MINUI_DATE}"
MINUI_PLATFORM=minime
source="https://github.com/jheronimus/MinUI/releases/download/${MINUI_VERSION}/MinUI-${MINUI_DATE}-${MINUI_DOT}-base.zip"
sha512sums="SKIP"

build() {
	cd "$srcdir" || return 1
	unzip -o "MinUI-${MINUI_DATE}-${MINUI_DOT}-base.zip"
	unzip -o MinUI.zip
}

package() {
	# Stage the UI payload to /alpine-output/boot/ui for post-image.sh
	# to consume.  The Alpine rootfs does not contain minui binaries;
	# they live on the SD card's FAT32 partition.
	mkdir -p /alpine-output/boot/ui/.ui
	cp -a "$srcdir"/.system/${MINUI_PLATFORM}/. /alpine-output/boot/ui/.ui/

	# Strip .elf extensions (MinUI convention; Minime expects bare names)
	for f in /alpine-output/boot/ui/.ui/bin/*.elf; do
		[ -f "$f" ] && mv -f "$f" "${f%.elf}"
	done

	# Move libmsettings.so next to binaries
	if [ -d "$srcdir"/.system/${MINUI_PLATFORM}/lib ]; then
		cp -a "$srcdir"/.system/${MINUI_PLATFORM}/lib/. \
			/alpine-output/boot/ui/.ui/bin/
	fi

	# Install cores
	if [ -d "$srcdir"/.system/${MINUI_PLATFORM}/cores ]; then
		mkdir -p /alpine-output/boot/ui/.cores
		cp -a "$srcdir"/.system/${MINUI_PLATFORM}/cores/. \
			/alpine-output/boot/ui/.cores/
	fi

	# Stamp for the Alpine rootfs
	install -dm755 "$pkgdir/var/lib/minime"
	install -Dm644 /dev/null "$pkgdir/var/lib/minime/minui.stamp"
}
