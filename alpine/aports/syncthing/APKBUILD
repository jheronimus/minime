# shellcheck shell=sh disable=SC2034,SC2154,SC3043
# abuild framework sets srcdir/builddir/pkgdir in the build env.
# Maintainer: Minime <maintainers@minime-os.local>
pkgname=syncthing
pkgver=2.1.2
pkgrel=0
pkgdesc="Continuous file synchronization (Alpine aarch64 musl build)"
url="https://github.com/syncthing/syncthing"
arch="aarch64"
license="MPL-2.0"
options="!strip !check"
makedepends="
	binutils-aarch64
	gcc-aarch64
	go
	linux-headers
"
source="$pkgname-$pkgver.tar.gz::https://github.com/syncthing/syncthing/archive/v$pkgver.tar.gz"
sha512sums="52d22bf25957e843a9501d06312a2471a4881f587b0a9e5496dfd757c791d281032453ba90a6a75f33bb7f374689caea9c347e9fcae6307e35445b4520d0caec  syncthing-2.1.2.tar.gz"

build() {
	cd "$srcdir/syncthing-$pkgver" || return 1
	export GOPROXY=https://proxy.golang.org,direct
	export GOOS=linux
	export GOARCH=arm64
	# Generate the assets protobufs; syncthing's build.go needs `go run`.
	(cd "$srcdir/syncthing-$pkgver" && go run build.go assets)
	go run build.go -goos linux -goarch arm64 -no-upgrade build
}

package() {
	cd "$srcdir/syncthing-$pkgver" || return 1
	install -Dm755 syncthing "$pkgdir/usr/bin/syncthing"
}
