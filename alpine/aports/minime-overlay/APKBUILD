# shellcheck shell=sh disable=SC2034,SC2154,SC3043
# abuild framework sets srcdir/builddir/pkgdir in the build env.
# Maintainer: Minime <maintainers@minime-os.local>
pkgname=minime-overlay
pkgver=1.0.0
pkgrel=0
pkgdesc="Minime filesystem layout, OpenRC services, immutable trait payload, and udev rules for the Alpine rootfs"
url="https://github.com/jheronimus/minime"
arch="aarch64"
license="MIT"
options="!strip !check"
makedepends="rsync"
source=""

# Alpine overlay package for base config, udev rules, and OpenRC services.
# The overlay preserves hostname, mounts, root access, telnet/ftp behavior,
# and the immutable trait payload under /usr/share/minime/traits.

build() {
	# Nothing to build; files/ is the entire payload.
	return 0
}

package() {
	local src="$startdir/files"
	local scripts_src="$startdir/../../board/common/scripts"
	local dst="$pkgdir"

	mkdir -p "$dst"

	# Mirror the source tree (etc/, usr/, etc.) into the package root.
	# The Alpine rootfs will receive it via `apk add minime-overlay`.
	# rsync -a preserves symlinks (runlevels/boot/<svc> -> ../../init.d/...);
	# the .apk tarball keeps them, and `apk add` restores them so OpenRC
	# can resolve each service at boot.
	rsync -a \
		--exclude='.git*' --exclude='Makefile' --exclude='README*' \
		--exclude='APKBUILD' --exclude='files' \
		"$src"/ "$dst"/

	# Install shared runtime scripts from the canonical source.
	mkdir -p "$dst/usr/share/minime/scripts"
	install -m 0755 \
		"$scripts_src/wifi.sh" \
		"$scripts_src/ui.sh" \
		"$scripts_src/traits.sh" \
		"$dst/usr/share/minime/scripts/"

	# Ensure executable bits on init.d / OpenRC services.
	if [ -d "$dst/etc/init.d" ]; then
		find "$dst/etc/init.d" -type f -exec chmod 0755 {} +
	fi
}
