#!/sbin/openrc-run
# shellcheck disable=SC2034
# ui: launch the UI (MinUI/Allium) and the headphone-jack watcher
# for the rk817ext sound card.  Runs in the background; the boot stage
# does not block on the UI lifecycle.

description="Minime UI (MinUI/Allium)"

command=":"
command_background="yes"
pidfile="/run/ui.pid"

depend() {
	after modules fb-unblank traits panfrost \
		bootsplash localmount
}

start() {
	ebegin "Starting UI"
	/usr/share/minime/scripts/ui start
	eend 0
}

stop() {
	ebegin "Stopping UI"
	/usr/share/minime/scripts/ui stop
	eend $?
}
