# shellcheck shell=sh disable=SC2034,SC2154,SC3043
# abuild framework sets srcdir/builddir/pkgdir in the build env.
# Maintainer: Minime <maintainers@minime-os.local>
pkgname=tinykernel
pkgver=7.1.4
pkgrel=0
pkgdesc="Minime minimal Linux kernel + DTBs for Alpine"
url="https://github.com/gregkh/linux"
arch="aarch64"
license="GPL-2.0-only"
options="!strip !check"
makedepends="
	bash
	bc
	bison
	flex
	gcc-aarch64
	binutils-aarch64
	linux-headers
	ncurses-dev
	openssl-dev
	perl
	python3
"

# Direct upstream tarball URL so the build is reproducible without aports sync.
# If you need the in-progress stable branch, switch to git://.
source="
	https://cdn.kernel.org/pub/linux/kernel/v${pkgver%%.*}.x/linux-${pkgver}.tar.xz
"
sha512sums="753b53b3f9a240b5838fe1156ad61f2356e2042941e571450492b5c8c46fd32140aede34fd4b074705650bac503deccec20ad9b8caee9d4c5fdc575401c76cc4  linux-7.1.4.tar.xz"

: "${DTB_BOARD:=rk3566}"
case "$DTB_BOARD" in
	rk3566)
		_dtbs="
			rockchip/rk3566-anbernic-rg-arc-d
			rockchip/rk3566-anbernic-rg-arc-s
			rockchip/rk3566-anbernic-rg353p
			rockchip/rk3566-anbernic-rg353ps
			rockchip/rk3566-anbernic-rg353v
			rockchip/rk3566-anbernic-rg353vs
			rockchip/rk3566-anbernic-rg503
			rockchip/rk3568-anbernic-rg-ds
		"
		;;
	rk3326)
		_dtbs="
			rockchip/rk3326-anbernic-rg351p
			rockchip/rk3326-anbernic-rg351m
			rockchip/rk3326-anbernic-rg351v
			rockchip/rk3326-anbernic-rg351mp
		"
		;;
	h700)
		_dtbs="
			allwinner/sun50i-h700-anbernic-rg28xx
			allwinner/sun50i-h700-anbernic-rg34xx
			allwinner/sun50i-h700-anbernic-rg34xx-sp
			allwinner/sun50i-h700-anbernic-rg35xx-2024
			allwinner/sun50i-h700-anbernic-rg35xx-2024-rev6-panel
			allwinner/sun50i-h700-anbernic-rg35xx-h
			allwinner/sun50i-h700-anbernic-rg35xx-h-rev6-panel
			allwinner/sun50i-h700-anbernic-rg35xx-plus
			allwinner/sun50i-h700-anbernic-rg35xx-plus-rev6-panel
			allwinner/sun50i-h700-anbernic-rg35xx-pro
			allwinner/sun50i-h700-anbernic-rg35xx-sp
			allwinner/sun50i-h700-anbernic-rg35xx-sp-v2-panel
			allwinner/sun50i-h700-anbernic-rg40xx-h
			allwinner/sun50i-h700-anbernic-rg40xx-h-v2-panel
			allwinner/sun50i-h700-anbernic-rg40xx-v
			allwinner/sun50i-h700-anbernic-rg40xx-v-v2-panel
			allwinner/sun50i-h700-anbernic-rgcubexx
		"
		;;
	*)
		echo "unsupported DTB_BOARD=$DTB_BOARD"
		exit 1
		;;
esac

build() {
	local src="$srcdir/linux-$pkgver"
	cd "$src" || return 1

	# 1. Apply Minime's kernel patch series.
	local patch_dir="/workspace/alpine/board/${DTB_BOARD}/patches/linux"
	if [ -d "$patch_dir" ]; then
		for p in "$patch_dir"/*.patch; do
			[ -f "$p" ] || continue
			msg "Applying $p"
			patch -p1 -N < "$p" || return 1
		done
	fi

	# 2. Copy custom DTS files.
	if [ "${DTB_BOARD}" = "h700" ]; then
		cp /workspace/alpine/board/h700/dts/*.dts arch/arm64/boot/dts/allwinner/
	elif [ "${DTB_BOARD}" = "rk3326" ]; then
		cp /workspace/alpine/board/rk3326/dts/*.dts arch/arm64/boot/dts/rockchip/
		echo 'dtb-$(CONFIG_ARCH_ROCKCHIP) += rk3326-anbernic-rg351p.dtb' >> arch/arm64/boot/dts/rockchip/Makefile
		echo 'dtb-$(CONFIG_ARCH_ROCKCHIP) += rk3326-anbernic-rg351mp.dtb' >> arch/arm64/boot/dts/rockchip/Makefile
	fi

	# 3. Merge kernel config:
	#    tiny-base.config -> tiny-<board>.config -> tiny-panfrost.config -> olddefconfig
	local cfg_src="/workspace/alpine"
	cat > .config <<-EOF
		# merged by APKBUILD build()
		# tiny-base.config first
	EOF
	cat "/workspace/alpine/board/common/tiny-base.config" >> .config
	cat "/workspace/alpine/board/${DTB_BOARD}/tiny-${DTB_BOARD}.config" >> .config
	cat "$cfg_src/board/common/tiny-panfrost.config" >> .config

	# 4. Resolve new options and surface any unresolved ones.
	local fw_stage="$srcdir/firmware"
	mkdir -p "$fw_stage"
	cp -rL /workspace/alpine/board/common/firmware/* "$fw_stage/"
	if [ -d "/workspace/alpine/board/${DTB_BOARD}/firmware" ]; then
		cp -rL /workspace/alpine/board/${DTB_BOARD}/firmware/* "$fw_stage/"
	fi
	sed -i "s|__MINIME_BOARD_FIRMWARE_DIR__|$fw_stage|g" .config
	sed -i 's|__MINIME_COMMON_FIRMWARE_DIR__|/workspace/alpine/board/common/firmware|g' .config
	make ARCH=arm64 CROSS_COMPILE=aarch64-alpine-linux-musl- olddefconfig

	# 5. Hard guard: CONFIG_DRM_PANFROST must be present, CONFIG_MALI_KBASE
	#    must not.  A future patch series that re-enables the proprietary
	#    Mali driver pair needs explicit opt-in, not a silent regression.
	grep -q "^CONFIG_DRM_PANFROST=y" .config \
		|| { echo "FATAL: CONFIG_DRM_PANFROST=y missing after olddefconfig"; return 1; }
	if grep -q "^CONFIG_MALI_KBASE=y\|^CONFIG_MALI_MIDGARD=y\|^CONFIG_MALI_BIFROST=y" .config; then
		echo "FATAL: proprietary Mali driver re-enabled by olddefconfig"; return 1
	fi

	# 6. Build kernel + DTBs + modules.
	local dtb_targets=""
	for dtb in $_dtbs; do
		dtb_targets="$dtb_targets ${dtb}.dtb"
	done
	make ARCH=arm64 CROSS_COMPILE=aarch64-alpine-linux-musl- -j"$JOBS" Image modules $dtb_targets
}

package() {
	local src="$srcdir/linux-$pkgver"
	cd "$src" || return 1

	# We do not install tinykernel into the rootfs; the Alpine build
	# script copies Image + dtbs + modules to /alpine-output/boot/ for
	# post-image.sh to consume.  abuild still needs a "package" function
	# to succeed, so emit a tiny stamp APK with the .config + patches.
	install -Dm644 .config "$pkgdir/var/lib/minime/tinykernel.config"
	install -Dm644 arch/arm64/boot/Image "$pkgdir/var/lib/minime/tinykernel.Image"
	for dtb in $_dtbs; do
		local out="$pkgdir/var/lib/minime/dtbs/${dtb##*/}.dtb"
		install -Dm644 "arch/arm64/boot/dts/${dtb}.dtb" "$out"
	done

	# Modules go to /alpine-output/boot/modules, not into the rootfs.
	mkdir -p /alpine-output/boot/modules
	make ARCH=arm64 CROSS_COMPILE=aarch64-alpine-linux-musl- \
		INSTALL_MOD_PATH=/alpine-output/boot/modules modules_install
	rm -f /alpine-output/boot/modules/lib/modules/*/build /alpine-output/boot/modules/lib/modules/*/source
}

# Staging hook: build_tinykernel() in scripts/build.sh runs after abuild
# to pick up /alpine-output/boot/Image + DTBs.  abuild's "rootpkg" target
# produces the .apk listed above.
