build() {
	cd "$srcdir" || return 1
	make CC="${CC:-gcc}" PKG_CONFIG="${PKG_CONFIG:-pkg-config}"
}

package() {
	cd "$srcdir" || return 1
	install -Dm755 bootsplash "$pkgdir/usr/bin/bootsplash"
}
