# shellcheck shell=sh disable=SC2034,SC2154,SC3043
# abuild framework sets srcdir/builddir/pkgdir in the build env.
# Maintainer: Minime <maintainers@minime-os.local>
pkgname=preloaded-roms
pkgver=1.0.0
pkgrel=0
pkgdesc="Free / shareware ROM bundle for the Minime SD-card userdata image"
url="https://github.com/jheronimus/minime"
arch="aarch64"
license="Free/Shareware"
options="!strip !check"
source=""
export PRELOADED_ROMS_VERSION=cc85d1accc3b3fb2d65786edc62d6604ea19f0b9

build() {
	local workdir="$srcdir/build"
	mkdir -p "$workdir"
	cd "$workdir" || return 1

	if [ ! -d roms ]; then
		cp -a /workspace/roms ./roms
	fi
}

package() {
	sh /workspace/roms/install.sh /alpine-output/boot/ui
	install -Dm644 /dev/null "$pkgdir/var/lib/minime/preloaded-roms.stamp"
}
