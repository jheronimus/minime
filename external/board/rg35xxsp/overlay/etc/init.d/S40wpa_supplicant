#!/bin/sh

DAEMON="wpa_supplicant"
PIDFILE="/var/run/wpa_supplicant.pid"
CONF_FILE="/etc/wpa_supplicant/wpa_supplicant.conf"

start() {
	printf "Starting wpa_supplicant: "
	mkdir -p /var/run/wpa_supplicant
	# If configuration file doesn't exist, write a default skeleton so it doesn't fail
	if [ ! -f "$CONF_FILE" ]; then
		mkdir -p "$(dirname "$CONF_FILE")"
		echo "ctrl_interface=DIR=/var/run/wpa_supplicant GROUP=wheel" > "$CONF_FILE"
		echo "update_config=1" >> "$CONF_FILE"
	fi

	# Find wireless interfaces
	IFACE=""
	for dev in /sys/class/net/*; do
		if [ -e "$dev"/wireless ] || [ -e "$dev"/phy80211 ]; then
			IFACE="${dev##*/}"
			break
		fi
	done
	if [ -z "$IFACE" ]; then
		IFACE="wlan0"
	fi

	start-stop-daemon -S -q -b -m -p "$PIDFILE" -x /usr/sbin/wpa_supplicant -- -i"$IFACE" -c"$CONF_FILE"
	status=$?
	if [ $status -eq 0 ]; then
		echo "OK"
	else
		echo "FAIL"
	fi
	return $status
}

stop() {
	printf "Stopping wpa_supplicant: "
	start-stop-daemon -K -q -p "$PIDFILE"
	status=$?
	if [ $status -eq 0 ]; then
		rm -f "$PIDFILE"
		rm -rf /var/run/wpa_supplicant
		echo "OK"
	else
		echo "FAIL"
	fi
	return $status
}

restart() {
	stop
	sleep 1
	start
}

case "$1" in
	start)
		start
		;;
	stop)
		stop
		;;
	restart|reload)
		restart
		;;
	*)
		echo "Usage: $0 {start|stop|restart}"
		exit 1
esac
