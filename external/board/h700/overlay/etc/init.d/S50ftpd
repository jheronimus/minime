#!/bin/sh

PIDFILE="/var/run/ftpd.pid"

start() {
	printf "Starting ftpd: "
	start-stop-daemon -S -q -b -m -p "$PIDFILE" -x /usr/bin/tcpsvd -- -vE 0.0.0.0 21 /usr/sbin/ftpd -w /mnt/sdcard
	status=$?
	if [ $status -eq 0 ]; then
		echo "OK"
	else
		echo "FAIL"
	fi
	return $status
}

stop() {
	printf "Stopping ftpd: "
	start-stop-daemon -K -q -p "$PIDFILE"
	status=$?
	if [ $status -eq 0 ]; then
		rm -f "$PIDFILE"
		echo "OK"
	else
		echo "FAIL"
	fi
	return $status
}

restart() {
	stop
	sleep 1
	start
}

case "$1" in
	start)
		start
		;;
	stop)
		stop
		;;
	restart|reload)
		restart
		;;
	*)
		echo "Usage: $0 {start|stop|restart}"
		exit 1
esac
