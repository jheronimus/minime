#!/bin/sh

DAEMON="telnetd"
PIDFILE="/var/run/telnetd.pid"

start() {
	printf "Starting telnetd: "
	start-stop-daemon -S -q -b -m -p "$PIDFILE" -x /usr/sbin/telnetd -- -F -l /usr/bin/autologin
	status=$?
	if [ $status -eq 0 ]; then
		echo "OK"
	else
		echo "FAIL"
	fi
	return $status
}

stop() {
	printf "Stopping telnetd: "
	start-stop-daemon -K -q -p "$PIDFILE"
	status=$?
	if [ $status -eq 0 ]; then
		rm -f "$PIDFILE"
		echo "OK"
	else
		echo "FAIL"
	fi
	return $status
}

restart() {
	stop
	sleep 1
	start
}

case "$1" in
	start)
		start
		;;
	stop)
		stop
		;;
	restart|reload)
		restart
		;;
	*)
		echo "Usage: $0 {start|stop|restart}"
		exit 1
esac
