#include "helpers.h"
#include <math.h>

// Convert image to grayscale
void grayscale(int height, int width, RGBTRIPLE image[height][width])
{
    // Loop over all pixels
    for (int i = 0; i < height; i++)
    {
        for (int j = 0; j < width; j++)
        {
            // Take average of red, green, and blue
            int average =
                round(image[i][j].rgbtRed + image[i][j].rgbtGreen + image[i][j].rgbtBlue) / 3.0;

            // Update pixel values
            image[i][j].rgbtRed = image[i][j].rgbtGreen = image[i][j].rgbtBlue = average;
        }
    }

    return;
}


// Convert image to sepia
void sepia(int height, int width, RGBTRIPLE image[height][width])
{
    // Loop over all pixels
    for (int i = 0; i < height; i++)
    {
        for (int j = 0; j < width; j++)
        {
            // Calculate sepia pixel values
            int sepiaRed = round(.393 * image[i][j].rgbtRed + .769 * image[i][j].rgbtGreen +
                                 .189 * image[i][j].rgbtBlue);
            sepiaRed = check_channel(sepiaRed);

            int sepiaGreen = round(.349 * image[i][j].rgbtRed + .686 * image[i][j].rgbtGreen +
                                   .168 * image[i][j].rgbtBlue);
            sepiaGreen = check_channel(sepiaGreen);

            int sepiaBlue = round(.272 * image[i][j].rgbtRed + .534 * image[i][j].rgbtGreen +
                                  .131 * image[i][j].rgbtBlue);
            sepiaBlue = check_channel(sepiaBlue);

            // Update pixel values
            image[i][j].rgbtRed = sepiaRed;
            image[i][j].rgbtGreen = sepiaGreen;
            image[i][j].rgbtBlue = sepiaBlue;
        }
    }

    return;
}

// check RGB channels for overflow
int check_channel(int color_value)
{
    if (color_value <= 255)
    {
        return color_value;
    }
    else
    {
        return 255;
    }
}

// Reflect image horizontally
void reflect(int height, int width, RGBTRIPLE image[height][width])
{
    // Loop over all pixels
    for (int i = 0; i < height; i++)
    {
        for (int j = 0; j < width / 2; j++) // width / 2 so that we don't reflect twice
        {
            // Swap pixels
            RGBTRIPLE buffer = image[i][j];
            image[i][j] = image[i][width - j - 1]; // -1 due to 0-indexing
            image[i][width - j - 1] = buffer;
        }
    }

    return;
}

// Blur image
void blur(int height, int width, RGBTRIPLE image[height][width])
{
    // Create a copy of image
    RGBTRIPLE copy[height][width];
    for (int i = 0; i < height; i++)
    {
        for (int j = 0; j < width; j++)
        {
            copy[i][j] = image[i][j];
            image[i][j].rgbtRed =
                round(copy[i + 1][j - 1].rgbtRed + copy[i + 1][j].rgbtRed +
                      copy[i + 1][j + 1].rgbtRed + copy[i][j - 1].rgbtRed + copy[i][j].rgbtRed +
                      copy[i][j + 1].rgbtRed + copy[i - 1][j - 1].rgbtRed + copy[i - 1][j].rgbtRed +
                      copy[i - 1][j + 1].rgbtRed) /
                9;
            image[i][j].rgbtRed = check_channel(image[i][j].rgbtRed);

            image[i][j].rgbtGreen = round(copy[i + 1][j - 1].rgbtGreen + copy[i + 1][j].rgbtGreen +
                                          copy[i + 1][j + 1].rgbtGreen + copy[i][j - 1].rgbtGreen +
                                          copy[i][j].rgbtGreen + copy[i][j + 1].rgbtGreen +
                                          copy[i - 1][j - 1].rgbtGreen + copy[i - 1][j].rgbtGreen +
                                          copy[i - 1][j + 1].rgbtGreen) /
                                    9;
            image[i][j].rgbtGreen = check_channel(image[i][j].rgbtGreen);

            image[i][j].rgbtBlue =
                round(copy[i + 1][j - 1].rgbtBlue + copy[i + 1][j].rgbtBlue +
                      copy[i + 1][j + 1].rgbtBlue + copy[i][j - 1].rgbtBlue + copy[i][j].rgbtBlue +
                      copy[i][j + 1].rgbtBlue + copy[i - 1][j - 1].rgbtBlue +
                      copy[i - 1][j].rgbtBlue + copy[i - 1][j + 1].rgbtBlue) /
                9;
            image[i][j].rgbtBlue = check_channel(image[i][j].rgbtBlue);
        }
    }
    return;
}

