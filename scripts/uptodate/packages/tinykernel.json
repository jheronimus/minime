{
  "name": "tinykernel",
  "source_type": "alpine_stable",
  "targets": [
    {
      "path": "alpine/aports/tinykernel/APKBUILD",
      "type": "alpine_apkbuild",
      "download_url": "https://cdn.kernel.org/pub/linux/kernel/v{version_major}.x/linux-{version}.tar.xz",
      "download_filename": "linux-{version}.tar.xz"
    },
    {
      "path": "buildroot/external/configs/common.config",
      "type": "regex",
      "pattern": "^BR2_LINUX_KERNEL_CUSTOM_VERSION_VALUE=\".*\"",
      "replacement": "BR2_LINUX_KERNEL_CUSTOM_VERSION_VALUE=\"{version}\""
    }
  ]
}
