{
  "name": "dufs",
  "source_type": "github_release",
  "github_repo": "sigoden/dufs",
  "strip_v_prefix": true,
  "targets": [
    {
      "path": "alpine/aports/dufs/APKBUILD",
      "type": "alpine_apkbuild",
      "download_url": "https://github.com/sigoden/dufs/archive/v{version}.tar.gz",
      "download_filename": "dufs-{version}.tar.gz"
    },
    {
      "path": "buildroot/external/package/dufs/dufs.mk",
      "type": "regex",
      "pattern": "^DUFS_VERSION = .*",
      "replacement": "DUFS_VERSION = {version}"
    },
    {
      "path": "buildroot/external/package/dufs/dufs.hash",
      "type": "buildroot_hash",
      "download_url": "https://github.com/sigoden/dufs/archive/v{version}.tar.gz",
      "download_filename": "dufs-{version}.tar.gz"
    }
  ]
}
