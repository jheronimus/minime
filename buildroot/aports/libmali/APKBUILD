pkgname=libmali
pkgver=0.1.0
pkgrel=1
pkgdesc="Proprietary ARM Mali user-space driver wrappers"
arch="aarch64"
url="https://github.com/ROCKNIX/libmali"
license="custom"
depends="libdrm"
makedepends="curl meson patchelf"
options="!check !strip !tracedeps"

_commit="0fe30426b822699f0a660268a6040fdafce229d1"
_mali_gpu="bifrost-g31"
_mali_version="g24p0"
_base_url="https://raw.githubusercontent.com/ROCKNIX/libmali/$_commit"

builddir="$srcdir/build"

# Text files to fetch (small, download instantly).
_text_files="
	meson.build
	meson_options.txt
	hook/meson.build
	hook/hook.c
	hook/injector.c
	data/vulkan/mali.json.in
	data/vulkan/mali_meson.json.in
	scripts/parse_name.sh
	scripts/grabber.sh
	scripts/fixup_gbm.sh
	scripts/fixup_egl_nox11.sh
	scripts/fixup_cl.sh
	scripts/fixup_dummy.sh
	scripts/fixup_nowrap.sh
	include/KHR/mali_khrplatform.h
	include/EGL/egl.h
	include/EGL/eglext.h
	include/EGL/eglext_angle.h
	include/EGL/eglmesaext.h
	include/EGL/eglplatform.h
	include/GBM/10.4.0/gbm.h
	include/GBM/17.1.0/gbm.h
	include/GBM/21.1.0/gbm.h
	include/GBM/23.1.3/gbm.h
	include/GBM/README
	include/GLES/egl.h
	include/GLES/glext.h
	include/GLES/glplatform.h
	include/GLES/gl.h
	include/GLES2/gl2ext.h
	include/GLES2/gl2.h
	include/GLES2/gl2platform.h
	include/GLES3/gl3ext.h
	include/GLES3/gl3.h
	include/GLES3/gl32.h
	include/GLES3/gl3platform.h
	include/GLES3/gl31.h
"

_fetch() {
	# curl flags:
	#   -f  fail on HTTP error
	#   -L  follow redirects
	#   -C- resume partial download
	#   --retry / --retry-delay  retry on transient errors
	#   --create-dirs            make parent dirs
	curl -fL -C - \
		--retry 10 --retry-delay 5 --retry-max-time 600 \
		--create-dirs \
		"$_base_url/$1" \
		-o "/tmp/rocknix-libmali/$1"
}

prepare() {
	# Read GPU/version from board.env if available
	for env_file in "$startdir"/../../board/*/board.env; do
		[ -f "$env_file" ] || continue
		printf '%s\n' "Found board env: $env_file"
		. "$env_file"
		break
	done
	local mali_gpu="${MALI_GPU:-$_mali_gpu}"
	local mali_version="${MALI_VERSION:-$_mali_version}"
	printf '%s\n' "Target GPU: $mali_gpu, Version: $mali_version"

	# Download everything to VM-local /tmp (avoids Virtio-FS write latency).
	# -C- resumes partial downloads, so a dropped connection is never fatal.
	mkdir -p /tmp/rocknix-libmali

	# --- Large binary (resume-capable) ---
	local lib="lib/aarch64-linux-gnu/libmali-${mali_gpu}-${mali_version}-gbm.so"
	_fetch "$lib"

	# --- Small text files ---
	for f in $_text_files; do
		[ -z "$f" ] && continue
		_fetch "$f"
	done

	# Mark scripts executable
	find /tmp/rocknix-libmali/scripts -name '*.sh' -exec chmod +x {} + 2>/dev/null || true

	# Create optimize_3 -> lib symlink expected by grabber.sh
	ln -sf lib /tmp/rocknix-libmali/optimize_3

	# Move into srcdir for the meson build
	rm -rf "$srcdir/rocknix-libmali"
	cp -r /tmp/rocknix-libmali "$srcdir/rocknix-libmali"
	rm -rf /tmp/rocknix-libmali
}

build() {
	for env_file in "$startdir"/../../board/*/board.env; do
		[ -f "$env_file" ] || continue
		. "$env_file"
		break
	done
	local mali_gpu="${MALI_GPU:-$_mali_gpu}"
	local mali_version="${MALI_VERSION:-$_mali_version}"

	meson setup \
		--prefix=/usr \
		--libdir=lib \
		-Darch=aarch64 \
		-Dgpu="$mali_gpu" \
		-Dversion="$mali_version" \
		-Dplatform=gbm \
		-Dopencl-icd=false \
		-Dkhr-header=false \
		-Dvendor-package=false \
		-Dwrappers=enabled \
		-Dhooks=true \
		"$srcdir/rocknix-libmali" \
		"$builddir"

	meson compile -C "$builddir"
}

package() {
	DESTDIR="$pkgdir" meson install -C "$builddir"

	# Drop headers — they conflict with distro glvnd/mesa headers
	rm -rf "$pkgdir/usr/include"
	rm -rf "$pkgdir/etc/ld.so.conf.d"

	# Inject hook dependency into every wrapper except libmali itself
	for lib in "$pkgdir"/usr/lib/lib*.so.*; do
		[ -f "$lib" ] || continue
		# skip symlinks (patchelf cannot patch symlinks) and the prebuilt binary
		[ -L "$lib" ] && continue
		case "$(basename "$lib")" in
			libmali.so*|libmali-hook.so*) continue ;;
		esac
		patchelf --add-needed libmali-hook.so.1 "$lib"
	done
	if [ -f "$pkgdir"/usr/lib/libmali-hook.so.1 ]; then
		patchelf --add-needed libmali.so.1 "$pkgdir"/usr/lib/libmali-hook.so.1
	fi

	# Standard unversioned symlinks
	cd "$pkgdir"/usr/lib
	[ -f libEGL.so.1 ] && ln -sf libEGL.so.1 libEGL.so
	[ -f libGLESv2.so.2 ] && ln -sf libGLESv2.so.2 libGLESv2.so
	[ -f libgbm.so.1 ] && ln -sf libgbm.so.1 libgbm.so
	# Fallback: if meson wrappers weren't built, link libmali.so itself
	[ -f libEGL.so.1 ] || ln -sf libmali.so libEGL.so.1
	[ -f libEGL.so ] || ln -sf libmali.so libEGL.so
	[ -f libGLESv2.so.2 ] || ln -sf libmali.so libGLESv2.so.2
	[ -f libGLESv2.so ] || ln -sf libmali.so libGLESv2.so
	[ -f libgbm.so.1 ] || ln -sf libmali.so libgbm.so.1
	[ -f libgbm.so ] || ln -sf libmali.so libgbm.so
	return 0
}
