--- a/package/llvm-project/llvm/llvm.mk	2026-06-17 00:00:17.000000000 +0300
+++ b/package/llvm-project/llvm/llvm.mk	2026-07-01 19:32:13.611186841 +0300
@@ -332,5 +332,101 @@
 endef
 LLVM_POST_INSTALL_TARGET_HOOKS = LLVM_DELETE_LLVM_TBLGEN_TARGET
 
+
+ifeq ($(BR2_PACKAGE_MINIME_PREBUILT_LLVM),y)
+LLVM_SOURCE =
+LLVM_OVERRIDE_SRCDIR = $(HOST_MINIME_PREBUILT_LLVM_BUILDDIR)/packages/llvm
+HOST_LLVM_OVERRIDE_SRCDIR = $(HOST_MINIME_PREBUILT_LLVM_BUILDDIR)/packages/host-llvm
+LLVM_EXTRA_DOWNLOADS =
+HOST_LLVM_EXTRA_DOWNLOADS =
+LLVM_DEPENDENCIES = host-minime-prebuilt-llvm host-llvm
+HOST_LLVM_DEPENDENCIES = host-minime-prebuilt-llvm host-patchelf
+LLVM_EXTRACT_CMDS = true
+HOST_LLVM_EXTRACT_CMDS = true
+LLVM_CONFIGURE_CMDS = true
+HOST_LLVM_CONFIGURE_CMDS = true
+LLVM_BUILD_CMDS = true
+HOST_LLVM_BUILD_CMDS = true
+
+define MINIME_RSYNC_HOST_PREBUILT
+	rsync -a \
+		--exclude='/bin/python*' \
+		--exclude='/include/python*/' \
+		--exclude='/include/expat*.h' \
+		--exclude='/lib/libexpat*' \
+		--exclude='/lib/libpython*' \
+		--exclude='/lib/pkgconfig/expat.pc' \
+		--exclude='/lib/pkgconfig/python*.pc' \
+		--exclude='/lib/python*/' \
+		$(1)/ $(HOST_DIR)/
+endef
+
+define MINIME_FIX_HOST_RPATH
+	find $(HOST_DIR)/bin $(HOST_DIR)/sbin -type f 2>/dev/null | while read f; do \
+		readelf -l "$$f" >/dev/null 2>&1 || continue; \
+		$(HOST_DIR)/bin/patchelf --set-rpath '$$ORIGIN/../lib' "$$f" 2>/dev/null || true; \
+	done
+endef
+
+define MINIME_WRAP_LLVM_CONFIG
+	if [ -x $(1) ]; then \
+		if [ ! -e $(1).br_real ]; then mv $(1) $(1).br_real; fi; \
+		printf '%s\n' '#!/bin/sh' \
+			'real="$${0}.br_real"' \
+			'old="$$($$real --prefix 2>/dev/null || true)"' \
+			'out="$$($$real "$$@")"' \
+			'status=$$?' \
+			'if [ -n "$$old" ]; then printf "%s\\n" "$$out" | sed "s#$$old#$(2)#g"; else printf "%s\\n" "$$out"; fi' \
+			'exit $$status' > $(1); \
+		chmod 0755 $(1); \
+	fi
+endef
+
+define MINIME_INSTALL_STAGING_LLVM_CONFIG
+	mkdir -p $(STAGING_DIR)/usr/bin; \
+	if [ -e $(HOST_DIR)/bin/llvm-config.br_real ]; then \
+		cp -f $(HOST_DIR)/bin/llvm-config.br_real $(STAGING_DIR)/usr/bin/llvm-config.br_real; \
+	else \
+		cp -f $(HOST_DIR)/bin/llvm-config $(STAGING_DIR)/usr/bin/llvm-config.br_real; \
+	fi; \
+	printf '%s\n' '#!/bin/sh' \
+		'real="$${0}.br_real"' \
+		'old="$$($$real --prefix 2>/dev/null || true)"' \
+		'out="$$($$real "$$@")"' \
+		'status=$$?' \
+		'if [ -n "$$old" ]; then printf "%s\\n" "$$out" | sed "s#$$old#$(STAGING_DIR)/usr#g"; else printf "%s\\n" "$$out"; fi' \
+		'exit $$status' > $(STAGING_DIR)/usr/bin/llvm-config; \
+	chmod 0755 $(STAGING_DIR)/usr/bin/llvm-config
+endef
+
+define HOST_LLVM_INSTALL_CMDS
+	if [ -d $(HOST_MINIME_PREBUILT_LLVM_BUILDDIR)/packages/host-llvm/host ]; then \
+		$(call MINIME_RSYNC_HOST_PREBUILT,$(HOST_MINIME_PREBUILT_LLVM_BUILDDIR)/packages/host-llvm/host); \
+	fi
+	if [ -d $(HOST_MINIME_PREBUILT_LLVM_BUILDDIR)/packages/host-llvm/staging ]; then \
+		rsync -a $(HOST_MINIME_PREBUILT_LLVM_BUILDDIR)/packages/host-llvm/staging/ $(STAGING_DIR)/; \
+	fi
+	$(call MINIME_FIX_HOST_RPATH)
+	$(call MINIME_WRAP_LLVM_CONFIG,$(HOST_DIR)/bin/llvm-config,$(HOST_DIR))
+	$(call MINIME_INSTALL_STAGING_LLVM_CONFIG)
+endef
+
+define LLVM_INSTALL_STAGING_CMDS
+	if [ -d $(HOST_MINIME_PREBUILT_LLVM_BUILDDIR)/packages/llvm/staging ]; then \
+		rsync -a $(HOST_MINIME_PREBUILT_LLVM_BUILDDIR)/packages/llvm/staging/ $(STAGING_DIR)/; \
+	fi
+	if [ -d $(HOST_MINIME_PREBUILT_LLVM_BUILDDIR)/packages/host-llvm/staging ]; then \
+		rsync -a $(HOST_MINIME_PREBUILT_LLVM_BUILDDIR)/packages/host-llvm/staging/ $(STAGING_DIR)/; \
+	fi
+	$(call MINIME_INSTALL_STAGING_LLVM_CONFIG)
+endef
+
+define LLVM_INSTALL_TARGET_CMDS
+	if [ -d $(HOST_MINIME_PREBUILT_LLVM_BUILDDIR)/packages/llvm/target ]; then \
+		rsync -a $(HOST_MINIME_PREBUILT_LLVM_BUILDDIR)/packages/llvm/target/ $(TARGET_DIR)/; \
+	fi
+endef
+endif
+
 $(eval $(cmake-package))
 $(eval $(host-cmake-package))
