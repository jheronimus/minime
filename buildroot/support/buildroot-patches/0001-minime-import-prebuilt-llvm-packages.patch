diff -urN a/package/llvm-project/clang/clang.mk b/package/llvm-project/clang/clang.mk
--- a/package/llvm-project/clang/clang.mk	2026-06-17 00:00:17.000000000 +0300
+++ b/package/llvm-project/clang/clang.mk	2026-07-01 08:41:35.498918807 +0300
@@ -155,5 +155,50 @@
 HOST_CLANG_POST_INSTALL_HOOKS += HOST_CLANG_TOOLCHAIN_WRAPPER_INSTALL
 HOST_CLANG_POST_INSTALL_HOOKS += HOST_CLANG_INSTALL_WRAPPER_AND_SIMPLE_SYMLINKS
 
+
+ifeq ($(BR2_PACKAGE_MINIME_PREBUILT_LLVM),y)
+CLANG_SOURCE =
+CLANG_DEPENDENCIES = host-minime-prebuilt-llvm llvm host-clang
+HOST_CLANG_DEPENDENCIES = host-minime-prebuilt-llvm host-llvm
+CLANG_EXTRACT_CMDS = true
+HOST_CLANG_EXTRACT_CMDS = true
+CLANG_CONFIGURE_CMDS = true
+HOST_CLANG_CONFIGURE_CMDS = true
+CLANG_BUILD_CMDS = true
+HOST_CLANG_BUILD_CMDS = true
+HOST_CLANG_POST_BUILD_HOOKS = HOST_CLANG_TOOLCHAIN_WRAPPER_BUILD
+HOST_CLANG_POST_INSTALL_HOOKS = HOST_CLANG_TOOLCHAIN_WRAPPER_INSTALL HOST_CLANG_INSTALL_CONFIG_FILE MINIME_HOST_CLANG_REWRAP
+
+define MINIME_HOST_CLANG_REWRAP
+	cd $(HOST_DIR)/bin; \
+	if [ -e clang-$(CLANG_VERSION_MAJOR).br_real ]; then \
+		for i in clang-$(CLANG_VERSION_MAJOR) clang clang++ clang-cl clang-cpp; do \
+			ln -snf toolchain-wrapper-clang $$i; \
+		done; \
+		for i in clang clang++ clang-cl clang-cpp; do \
+			ln -snf clang-$(CLANG_VERSION_MAJOR).br_real $$i.br_real; \
+		done; \
+	fi
+endef
+
+define HOST_CLANG_INSTALL_CMDS
+	if [ -d $(HOST_MINIME_PREBUILT_LLVM_BUILDDIR)/packages/host-clang/host ]; then \
+		rsync -a $(HOST_MINIME_PREBUILT_LLVM_BUILDDIR)/packages/host-clang/host/ $(HOST_DIR)/; \
+	fi
+endef
+
+define CLANG_INSTALL_STAGING_CMDS
+	if [ -d $(HOST_MINIME_PREBUILT_LLVM_BUILDDIR)/packages/clang/staging ]; then \
+		rsync -a $(HOST_MINIME_PREBUILT_LLVM_BUILDDIR)/packages/clang/staging/ $(STAGING_DIR)/; \
+	fi
+endef
+
+define CLANG_INSTALL_TARGET_CMDS
+	if [ -d $(HOST_MINIME_PREBUILT_LLVM_BUILDDIR)/packages/clang/target ]; then \
+		rsync -a $(HOST_MINIME_PREBUILT_LLVM_BUILDDIR)/packages/clang/target/ $(TARGET_DIR)/; \
+	fi
+endef
+endif
+
 $(eval $(cmake-package))
 $(eval $(host-cmake-package))
