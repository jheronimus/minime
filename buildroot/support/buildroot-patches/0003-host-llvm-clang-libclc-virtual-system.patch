diff -urN br_clean/package/llvm-project/clang/clang.mk buildroot/package/llvm-project/clang/clang.mk
--- br_clean/package/llvm-project/clang/clang.mk	2026-06-08 23:39:13
+++ buildroot/package/llvm-project/clang/clang.mk	2026-06-16 13:47:04
@@ -101,7 +101,9 @@
 	$(INSTALL) -D -m 0755 $(HOST_CLANG_BUILDDIR)/bin/clang-tblgen \
 		$(HOST_DIR)/bin/clang-tblgen
 endef
+ifneq ($(BR2_PACKAGE_HOST_LLVM_SYSTEM),y)
 HOST_CLANG_POST_INSTALL_HOOKS = HOST_CLANG_INSTALL_CLANG_TBLGEN
+endif
 
 # This option must be enabled to link libclang dynamically against libLLVM.so
 HOST_CLANG_CONF_OPTS += -DLLVM_LINK_LLVM_DYLIB=ON
@@ -125,9 +127,11 @@
 	echo "--target=$(GNU_TARGET_NAME)" >> $(HOST_DIR)/lib/clang/$(CLANG_VERSION_MAJOR)/$(GNU_TARGET_NAME).cfg
 endef
 
+ifneq ($(BR2_PACKAGE_HOST_LLVM_SYSTEM),y)
 HOST_CLANG_POST_INSTALL_HOOKS += HOST_CLANG_INSTALL_CONFIG_FILE
 HOST_CLANG_TOOLCHAIN_WRAPPER_ARGS += -DBR_CLANG_CONFIG_FILE="\"--config=$(HOST_DIR)/lib/clang/$(CLANG_VERSION_MAJOR)/$(GNU_TARGET_NAME).cfg\""
 endif
+endif
 
 define HOST_CLANG_INSTALL_WRAPPER_AND_SIMPLE_SYMLINKS
 	$(Q)cd $(HOST_DIR)/bin; \
@@ -153,9 +157,38 @@
 endef
 
 HOST_CLANG_TOOLCHAIN_WRAPPER_ARGS += -DBR_CROSS_PATH_SUFFIX='".br_real"'
+ifneq ($(BR2_PACKAGE_HOST_LLVM_SYSTEM),y)
 HOST_CLANG_POST_BUILD_HOOKS += HOST_CLANG_TOOLCHAIN_WRAPPER_BUILD
 HOST_CLANG_POST_INSTALL_HOOKS += HOST_CLANG_TOOLCHAIN_WRAPPER_INSTALL
 HOST_CLANG_POST_INSTALL_HOOKS += HOST_CLANG_INSTALL_WRAPPER_AND_SIMPLE_SYMLINKS
+endif
 
 $(eval $(cmake-package))
+ifeq ($(BR2_PACKAGE_HOST_LLVM_SYSTEM),y)
+HOST_CLANG_SYSTEM_VERSION = 22
+HOST_CLANG_LIBDIR = /usr/lib/$(HOSTARCH)-linux-gnu
+HOST_CLANG_LLVM_PREFIX = /usr/lib/llvm-$(HOST_CLANG_SYSTEM_VERSION)
+
+define HOST_CLANG_INSTALL_CMDS
+	$(INSTALL) -d $(HOST_DIR)/bin
+	ln -sf /usr/bin/clang-$(HOST_CLANG_SYSTEM_VERSION) $(HOST_DIR)/bin/clang
+	ln -sf /usr/bin/clang-$(HOST_CLANG_SYSTEM_VERSION) $(HOST_DIR)/bin/clang-$(HOST_CLANG_SYSTEM_VERSION)
+	ln -sf /usr/bin/clang++-$(HOST_CLANG_SYSTEM_VERSION) $(HOST_DIR)/bin/clang++
+	ln -sf /usr/bin/clang-cpp-$(HOST_CLANG_SYSTEM_VERSION) $(HOST_DIR)/bin/clang-cpp
+	ln -sf /usr/bin/clang-tblgen-$(HOST_CLANG_SYSTEM_VERSION) $(HOST_DIR)/bin/clang-tblgen
+
+	$(INSTALL) -d $(HOST_DIR)/lib
+	ln -sf $(HOST_CLANG_LIBDIR)/libclang-$(HOST_CLANG_SYSTEM_VERSION).so.1 $(HOST_DIR)/lib/libclang.so
+	ln -sf $(HOST_CLANG_LIBDIR)/libclang-$(HOST_CLANG_SYSTEM_VERSION).so.1 $(HOST_DIR)/lib/libclang.so.1
+	ln -sf $(HOST_CLANG_LIBDIR)/libclang-$(HOST_CLANG_SYSTEM_VERSION).so.1 $(HOST_DIR)/lib/libclang-$(HOST_CLANG_SYSTEM_VERSION).so.$(HOST_CLANG_SYSTEM_VERSION)
+	ln -sf $(HOST_CLANG_LIBDIR)/libclang-cpp.so.$(HOST_CLANG_SYSTEM_VERSION).1 $(HOST_DIR)/lib/libclang-cpp.so
+	ln -sf $(HOST_CLANG_LIBDIR)/libclang-cpp.so.$(HOST_CLANG_SYSTEM_VERSION).1 $(HOST_DIR)/lib/libclang-cpp.so.$(HOST_CLANG_SYSTEM_VERSION).1
+
+	$(INSTALL) -d $(HOST_DIR)/lib/cmake/clang
+	cp -a $(HOST_CLANG_LLVM_PREFIX)/lib/cmake/clang/. $(HOST_DIR)/lib/cmake/clang/
+endef
+
+$(eval $(host-generic-package))
+else
 $(eval $(host-cmake-package))
+endif
diff -urN br_clean/package/llvm-project/libclc/libclc.mk buildroot/package/llvm-project/libclc/libclc.mk
--- br_clean/package/llvm-project/libclc/libclc.mk	2026-06-08 23:39:13
+++ buildroot/package/llvm-project/libclc/libclc.mk	2026-06-16 13:47:04
@@ -45,4 +45,8 @@
 	-DLIBCLC_TARGETS_TO_BUILD=spirv64-mesa3d-
 
 $(eval $(cmake-package))
+ifeq ($(BR2_PACKAGE_HOST_LLVM_SYSTEM),y)
+$(eval $(host-virtual-package))
+else
 $(eval $(host-cmake-package))
+endif
diff -urN br_clean/package/llvm-project/llvm/llvm.mk buildroot/package/llvm-project/llvm/llvm.mk
--- br_clean/package/llvm-project/llvm/llvm.mk	2026-06-08 23:39:13
+++ buildroot/package/llvm-project/llvm/llvm.mk	2026-06-16 13:47:10
@@ -298,7 +298,9 @@
 	$(INSTALL) -D -m 0755 $(HOST_DIR)/bin/llvm-config \
 		$(STAGING_DIR)/usr/bin/llvm-config
 endef
+ifneq ($(BR2_PACKAGE_HOST_LLVM_SYSTEM),y)
 HOST_LLVM_POST_INSTALL_HOOKS = LLVM_COPY_LLVM_CONFIG_TO_STAGING_DIR
+endif
 
 # The llvm-symbolizer binary is used by the Compiler-RT Fuzzer
 # and AddressSanitizer tools on the target for stack traces.
@@ -322,4 +324,35 @@
 LLVM_POST_INSTALL_TARGET_HOOKS = LLVM_DELETE_LLVM_TBLGEN_TARGET
 
 $(eval $(cmake-package))
+ifeq ($(BR2_PACKAGE_HOST_LLVM_SYSTEM),y)
+HOST_LLVM_SYSTEM_VERSION = 22
+HOST_LLVM_LIBDIR = /usr/lib/$(HOSTARCH)-linux-gnu
+HOST_LLVM_LLVM_PREFIX = /usr/lib/llvm-$(HOST_LLVM_SYSTEM_VERSION)
+HOST_LLVM_LIBCLC_DIR = $(HOST_LLVM_LLVM_PREFIX)/share/libclc
+
+define HOST_LLVM_INSTALL_CMDS
+	$(INSTALL) -d $(HOST_DIR)/bin
+	ln -sf /usr/bin/llvm-config-$(HOST_LLVM_SYSTEM_VERSION) $(HOST_DIR)/bin/llvm-config
+	ln -sf /usr/bin/llvm-tblgen-$(HOST_LLVM_SYSTEM_VERSION) $(HOST_DIR)/bin/llvm-tblgen
+	ln -sf /usr/bin/llvm-dis-$(HOST_LLVM_SYSTEM_VERSION) $(HOST_DIR)/bin/llvm-dis
+
+	$(INSTALL) -d $(HOST_DIR)/lib
+	ln -sf $(HOST_LLVM_LIBDIR)/libLLVM.so.$(HOST_LLVM_SYSTEM_VERSION).1 $(HOST_DIR)/lib/libLLVM.so
+	ln -sf $(HOST_LLVM_LIBDIR)/libLLVM.so.$(HOST_LLVM_SYSTEM_VERSION).1 $(HOST_DIR)/lib/libLLVM.so.$(HOST_LLVM_SYSTEM_VERSION).1
+	ln -sf $(HOST_LLVM_LLVM_PREFIX)/lib/libLTO.so.$(HOST_LLVM_SYSTEM_VERSION).1 $(HOST_DIR)/lib/libLTO.so
+	ln -sf $(HOST_LLVM_LLVM_PREFIX)/lib/libLTO.so.$(HOST_LLVM_SYSTEM_VERSION).1 $(HOST_DIR)/lib/libLTO.so.$(HOST_LLVM_SYSTEM_VERSION).1
+	ln -sf $(HOST_LLVM_LLVM_PREFIX)/lib/libLTO.so.$(HOST_LLVM_SYSTEM_VERSION).1 $(HOST_DIR)/lib/libLTO.so.$(HOST_LLVM_SYSTEM_VERSION)
+
+	$(INSTALL) -d $(HOST_DIR)/lib/cmake/llvm
+	cp -a $(HOST_LLVM_LLVM_PREFIX)/lib/cmake/llvm/. $(HOST_DIR)/lib/cmake/llvm/
+
+	$(INSTALL) -d $(HOST_DIR)/share/libclc
+	cp -a $(HOST_LLVM_LIBCLC_DIR)/. $(HOST_DIR)/share/libclc/
+
+	ln -sf $(HOST_DIR)/bin/llvm-config $(STAGING_DIR)/usr/bin/llvm-config
+endef
+
+$(eval $(host-generic-package))
+else
 $(eval $(host-cmake-package))
+endif
