# Re-enables U-Boot building for RK3566 bootloader prebuild workflow.
# Used ONLY by .github/workflows/bootloader.yml. The firmware defconfig
# (minime_rk3566.config) does NOT build U-Boot; bootloader blobs are staged
# at image time from alpine/bootloader/rk3566/.
#
# Hybrid: mainline U-Boot + committed rkbin BL31 blob at
# alpine/bootloader/rk3566/rkbin/bl31.elf (rkbin is preferred over mainline
# TF-A on RK3568/RK3566 due to suspend + GPU reset quirks).

BR2_PACKAGE_ROCKCHIP_RKBIN=y
BR2_PACKAGE_ROCKCHIP_RKBIN_TPL_FILENAME="bin/rk35/rk3566_ddr_1056MHz_v1.25.bin"

BR2_TARGET_UBOOT=y
BR2_TARGET_UBOOT_BUILD_SYSTEM_KCONFIG=y
BR2_TARGET_UBOOT_CUSTOM_VERSION=y
BR2_TARGET_UBOOT_CUSTOM_VERSION_VALUE="__UBOOT_VERSION__"
BR2_TARGET_UBOOT_BOARD_DEFCONFIG="anbernic-rgxx3-rk3566"
BR2_TARGET_UBOOT_CONFIG_FRAGMENT_FILES="$(BR2_EXTERNAL_MINIME_PATH)/../../alpine/board/common/uboot.config"
BR2_TARGET_UBOOT_NEEDS_DTC=y
BR2_TARGET_UBOOT_NEEDS_OPENSSL=y
BR2_TARGET_UBOOT_NEEDS_ROCKCHIP_RKBIN=y
BR2_TARGET_UBOOT_USE_BINMAN=y
BR2_TARGET_UBOOT_FORMAT_ITB=y
BR2_TARGET_UBOOT_CUSTOM_MAKEOPTS="BL31=$(BR2_EXTERNAL_MINIME_PATH)/../../alpine/bootloader/rk3566/rkbin/bl31.elf"