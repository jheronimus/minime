# Common section: shared across all Minime board images.
# Keep this section identical in minime_h700_defconfig, minime_rk3326_defconfig and minime_rk3566_defconfig.

# Toolchain
BR2_aarch64=y
BR2_TOOLCHAIN_EXTERNAL=y
BR2_TOOLCHAIN_EXTERNAL_ARM_AARCH64=y
BR2_TARGET_LDFLAGS="-fuse-ld=mold"

# Download / cache
BR2_DL_DIR="~/.buildroot-dl"
BR2_DOWNLOAD_FORCE_CHECK_HASHES=y
BR2_CCACHE=y
BR2_CCACHE_DIR="~/.buildroot-ccache"
BR2_CCACHE_INITIAL_SETUP="--max-size=30G"

# Optimisation
BR2_OPTIMIZE_3=y
BR2_ENABLE_LTO=y

# Rootfs base
BR2_TARGET_GENERIC_HOSTNAME="minime"
BR2_ROOTFS_DEVICE_CREATION_DYNAMIC_EUDEV=y
BR2_TARGET_GENERIC_ROOT_PASSWD="root"
BR2_ROOTFS_OVERLAY="$(BR2_EXTERNAL_MINIME_PATH)/board/common/overlay"
BR2_ROOTFS_POST_BUILD_SCRIPT="$(BR2_EXTERNAL_MINIME_PATH)/board/common/post-build.sh"
BR2_ROOTFS_POST_IMAGE_SCRIPT="$(BR2_EXTERNAL_MINIME_PATH)/board/common/post-image.sh"
BR2_TARGET_ROOTFS_TAR=y

# Kernel base
BR2_LINUX_KERNEL=y
BR2_LINUX_KERNEL_CUSTOM_VERSION=y
BR2_LINUX_KERNEL_CUSTOM_VERSION_VALUE="7.0.10"
BR2_LINUX_KERNEL_USE_CUSTOM_CONFIG=y
BR2_LINUX_KERNEL_CUSTOM_CONFIG_FILE="$(BR2_EXTERNAL_MINIME_PATH)/board/common/tiny-base.config"
BR2_LINUX_KERNEL_DTS_SUPPORT=y

# BusyBox
BR2_PACKAGE_BUSYBOX_CONFIG_FRAGMENT_FILES="$(BR2_EXTERNAL_MINIME_PATH)/board/common/busybox.config"

# Bluetooth / Wi-Fi base
BR2_PACKAGE_DBUS=y
BR2_PACKAGE_BLUEZ5_UTILS=y
BR2_PACKAGE_BLUEZ5_UTILS_CLIENT=y
BR2_PACKAGE_BLUEZ5_UTILS_PLUGINS_HID=y
BR2_PACKAGE_BLUEZ5_UTILS_PLUGINS_AUDIO=y
BR2_PACKAGE_BLUEZ_ALSA=y
BR2_PACKAGE_WIRELESS_REGDB=y
BR2_PACKAGE_WPA_SUPPLICANT=y
BR2_PACKAGE_WPA_SUPPLICANT_CLI=y

# Audio
BR2_PACKAGE_ALSA_UTILS=y
# BR2_PACKAGE_ALSA_UTILS_ALSACTL is not set
# BR2_PACKAGE_ALSA_UTILS_ALSAMIXER is not set
BR2_PACKAGE_ALSA_UTILS_AMIXER=y

# Filesystem / partitioning
BR2_PACKAGE_DOSFSTOOLS=y
BR2_PACKAGE_DOSFSTOOLS_MKFS_FAT=y
BR2_PACKAGE_FATRESIZE=y
BR2_PACKAGE_ZSTD=y

# SDL / graphics
BR2_PACKAGE_SDL2=y
BR2_PACKAGE_SDL2_KMSDRM=y
BR2_PACKAGE_SDL2_OPENGLES=y
BR2_PACKAGE_SDL2_IMAGE=y
BR2_PACKAGE_SDL2_IMAGE_PNG=y
BR2_PACKAGE_SDL2_TTF=y
BR2_PACKAGE_LIBPNG=y

# System libraries
BR2_PACKAGE_LIBXML2=y
BR2_PACKAGE_LIBFFI=y
BR2_PACKAGE_LIBEDIT=y

# Network / mDNS
BR2_PACKAGE_MDNSD=y
BR2_PACKAGE_UTIL_LINUX_PARTX=y

# U-Boot base
BR2_TARGET_UBOOT=y
BR2_TARGET_UBOOT_BUILD_SYSTEM_KCONFIG=y
BR2_TARGET_UBOOT_CUSTOM_VERSION=y
BR2_TARGET_UBOOT_CUSTOM_VERSION_VALUE="2026.04"
BR2_TARGET_UBOOT_NEEDS_DTC=y
BR2_TARGET_UBOOT_NEEDS_OPENSSL=y
BR2_TARGET_UBOOT_SPL=y

# Platform specific section: per-board overrides and additional packages.

BR2_cortex_a55=y
BR2_GLOBAL_PATCH_DIR="$(BR2_EXTERNAL_MINIME_PATH)/board/rk3566/patches"
BR2_ROOTFS_POST_SCRIPT_ARGS="-c $(BR2_EXTERNAL_MINIME_PATH)/board/rk3566/genimage.cfg"
BR2_LINUX_KERNEL_CONFIG_FRAGMENT_FILES="$(BR2_EXTERNAL_MINIME_PATH)/board/rk3566/tiny-rk3566.config"
BR2_LINUX_KERNEL_INTREE_DTS_NAME="rockchip/rk3566-anbernic-rg-arc-d rockchip/rk3566-anbernic-rg-arc-s rockchip/rk3566-anbernic-rg353p rockchip/rk3566-anbernic-rg353ps rockchip/rk3566-anbernic-rg353v rockchip/rk3566-anbernic-rg353vs rockchip/rk3566-anbernic-rg503 rockchip/rk3568-anbernic-rg-ds"

BR2_PACKAGE_ROCKCHIP_RKBIN=y
BR2_PACKAGE_ROCKCHIP_RKBIN_TPL_FILENAME="bin/rk35/rk3566_ddr_1056MHz_v1.23.bin"

BR2_TARGET_UBOOT_BOARD_DEFCONFIG="anbernic-rgxx3-rk3566"
BR2_TARGET_UBOOT_CONFIG_FRAGMENT_FILES="$(BR2_EXTERNAL_MINIME_PATH)/board/rk3566/uboot.config"
BR2_TARGET_UBOOT_NEEDS_ROCKCHIP_RKBIN=y
BR2_TARGET_UBOOT_USE_BINMAN=y
BR2_TARGET_UBOOT_FORMAT_ITB=y
BR2_TARGET_UBOOT_CUSTOM_MAKEOPTS="BL31=$(BR2_EXTERNAL_MINIME_PATH)/board/rk3566/prebuilt/rocknix-rkbin/rk3568_bl31_v1.45.elf"

BR2_PACKAGE_LIBMALI=y
BR2_PACKAGE_LIBMALI_GPU_BIFROST_G52=y
BR2_PACKAGE_MALI_KBASE=y
BR2_PACKAGE_ALLIUM=y
BR2_PACKAGE_DRKHRSE_MIYOO_BEZELS=y
BR2_PACKAGE_RETROARCH_CORES=y
