# Toolchain: Arm AArch64 glibc
BR2_TOOLCHAIN_EXTERNAL_ARM_AARCH64=y

# Prebuilt LLVM channel for this toolchain flavor
BR2_PACKAGE_MINIME_PREBUILT_LLVM_CHANNEL_URL="https://raw.githubusercontent.com/jheronimus/minime/main/buildroot/external/package/minime-prebuilt-llvm/channels/arm-glibc/2026.05/stable.json"
