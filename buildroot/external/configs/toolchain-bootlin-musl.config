# Toolchain: Bootlin AArch64 musl (stable)
BR2_TOOLCHAIN_EXTERNAL_BOOTLIN=y
BR2_TOOLCHAIN_EXTERNAL_BOOTLIN_AARCH64_MUSL_STABLE=y

# Prebuilt LLVM channel for this toolchain flavor
BR2_PACKAGE_MINIME_PREBUILT_LLVM_CHANNEL_URL="https://raw.githubusercontent.com/jheronimus/minime/main/buildroot/external/package/minime-prebuilt-llvm/channels/bootlin-musl/2026.05/stable.json"
