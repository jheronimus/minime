BR2_cortex_a35=y
BR2_GLOBAL_PATCH_DIR="$(BR2_EXTERNAL_MINIME_PATH)/../../alpine/board/rk3326/patches"
BR2_ROOTFS_POST_SCRIPT_ARGS="-c $(BR2_EXTERNAL_MINIME_PATH)/../../alpine/board/common/genimage.cfg -b rk3326"
BR2_LINUX_KERNEL_CONFIG_FRAGMENT_FILES="$(BR2_EXTERNAL_MINIME_PATH)/../../alpine/board/rk3326/tiny-rk3326.config $(BR2_EXTERNAL_MINIME_PATH)/../../alpine/board/rk3326/tiny-dongles.config $(BR2_EXTERNAL_MINIME_PATH)/../../alpine/board/common/tiny-libmali.config"
BR2_LINUX_KERNEL_INTREE_DTS_NAME="rockchip/rk3326-anbernic-rg351p rockchip/rk3326-anbernic-rg351m rockchip/rk3326-anbernic-rg351v rockchip/rk3326-anbernic-rg351mp"

BR2_PACKAGE_LIBMALI_BIFROST_G31_G13P0=y

BR2_DEFCONFIG="$(BR2_EXTERNAL_MINIME_PATH)/configs/rk3326.config"
