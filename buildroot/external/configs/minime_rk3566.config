BR2_cortex_a55=y
BR2_GLOBAL_PATCH_DIR="$(BR2_EXTERNAL_MINIME_PATH)/../../alpine/board/rk3566/patches"
BR2_ROOTFS_POST_SCRIPT_ARGS="-c $(BR2_EXTERNAL_MINIME_PATH)/../../alpine/board/common/genimage.cfg -b rk3566"
BR2_LINUX_KERNEL_CONFIG_FRAGMENT_FILES="$(BR2_EXTERNAL_MINIME_PATH)/../../alpine/board/rk3566/tiny-rk3566.config $(BR2_EXTERNAL_MINIME_PATH)/board/common/tiny-libmali.config"
BR2_LINUX_KERNEL_INTREE_DTS_NAME="rockchip/rk3566-anbernic-rg-arc-d rockchip/rk3566-anbernic-rg-arc-s rockchip/rk3566-anbernic-rg353p rockchip/rk3566-anbernic-rg353ps rockchip/rk3566-anbernic-rg353v rockchip/rk3566-anbernic-rg353vs rockchip/rk3566-anbernic-rg503 rockchip/rk3568-anbernic-rg-ds"

BR2_PACKAGE_LIBMALI_BIFROST_G52_G13P0=y
BR2_PACKAGE_MINUI=y
BR2_PACKAGE_PRELOADED_ROMS=y
BR2_DEFCONFIG="$(BR2_EXTERNAL_MINIME_PATH)/configs/minime_rk3566_defconfig"
