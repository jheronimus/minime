config BR2_PACKAGE_MINIME_PREBUILT_LLVM
	bool "Minime prebuilt LLVM package set"
	help
	  Import Buildroot-built LLVM/Clang/libclc/SPIR-V package outputs
	  from jheronimus/minime instead of rebuilding them locally.

config BR2_PACKAGE_MINIME_PREBUILT_LLVM_CHANNEL_URL
	string "Prebuilt LLVM channel manifest URL"
	depends on BR2_PACKAGE_MINIME_PREBUILT_LLVM
	default "https://raw.githubusercontent.com/jheronimus/minime/llvm-channels/channels/bootlin-musl/2026.05.1/stable.json"
	help
	  URL of a stable.json manifest. The manifest points at the
	  assembled llvm-rN.tar.xz artifact (named by "asset" / "url" and
	  verified against the top-level "sha256") and, when the assembled
	  archive exceeds GitHub's 2 GiB release-asset cap, includes a
	  "parts" array describing each chunk; the fetcher reassembles the
	  chunks before extraction.

config BR2_PACKAGE_MINIME_PREBUILT_LLVM_FLAVOR
	string "Prebuilt LLVM flavor"
	depends on BR2_PACKAGE_MINIME_PREBUILT_LLVM
	help
	  The flavor of the toolchain (e.g. bootlin-musl, arm-glibc)

