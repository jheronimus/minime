config BR2_PACKAGE_LIBMALI
	bool "libmali"
	depends on BR2_aarch64
	depends on !BR2_PACKAGE_MESA3D_GALLIUM_DRIVER_PANFROST
	select BR2_PACKAGE_HAS_LIBEGL
	select BR2_PACKAGE_HAS_LIBGLES
	select BR2_PACKAGE_HAS_LIBGBM
	select BR2_PACKAGE_LIBDRM
	help
	  Proprietary ARM Mali user-space driver wrappers.
	  Provides OpenGL ES, EGL, and GBM libraries.

if BR2_PACKAGE_LIBMALI

choice
	prompt "Mali GPU Variant"
	default BR2_PACKAGE_LIBMALI_BIFROST_G31_G24P0
	help
	  Select the specific Mali GPU model and driver version variant.

config BR2_PACKAGE_LIBMALI_BIFROST_G31_G24P0
	bool "Bifrost G31 G24P0 (H700)"

config BR2_PACKAGE_LIBMALI_BIFROST_G31_G13P0
	bool "Bifrost G31 G13P0 (RK3326)"

config BR2_PACKAGE_LIBMALI_BIFROST_G31_G2P0
	bool "Bifrost G31 G2P0 (RK3326)"

config BR2_PACKAGE_LIBMALI_BIFROST_G52_G13P0
	bool "Bifrost G52 G13P0 (RK3566)"

config BR2_PACKAGE_LIBMALI_BIFROST_G52_G24P0
	bool "Bifrost G52 G24P0 (RK3566)"

config BR2_PACKAGE_LIBMALI_BIFROST_G52_G2P0
	bool "Bifrost G52 G2P0 (RK3566)"

endchoice

config BR2_PACKAGE_LIBMALI_GPU
	string
	default "bifrost-g31" if BR2_PACKAGE_LIBMALI_BIFROST_G31_G24P0 || BR2_PACKAGE_LIBMALI_BIFROST_G31_G13P0 || BR2_PACKAGE_LIBMALI_BIFROST_G31_G2P0
	default "bifrost-g52" if BR2_PACKAGE_LIBMALI_BIFROST_G52_G13P0 || BR2_PACKAGE_LIBMALI_BIFROST_G52_G24P0 || BR2_PACKAGE_LIBMALI_BIFROST_G52_G2P0

config BR2_PACKAGE_LIBMALI_GPU_VERSION
	string
	default "g24p0" if BR2_PACKAGE_LIBMALI_BIFROST_G31_G24P0 || BR2_PACKAGE_LIBMALI_BIFROST_G52_G24P0
	default "g13p0" if BR2_PACKAGE_LIBMALI_BIFROST_G31_G13P0 || BR2_PACKAGE_LIBMALI_BIFROST_G52_G13P0
	default "g2p0" if BR2_PACKAGE_LIBMALI_BIFROST_G31_G2P0 || BR2_PACKAGE_LIBMALI_BIFROST_G52_G2P0

config BR2_PACKAGE_PROVIDES_LIBEGL
	default "libmali"

config BR2_PACKAGE_PROVIDES_LIBGLES
	default "libmali"

config BR2_PACKAGE_PROVIDES_LIBGBM
	default "libmali"

endif
