config BR2_PACKAGE_LIBMALI
	bool "libmali"
	depends on BR2_aarch64
	select BR2_PACKAGE_HAS_LIBEGL
	select BR2_PACKAGE_HAS_LIBGLES
	select BR2_PACKAGE_HAS_LIBGBM
	select BR2_PACKAGE_LIBDRM
	help
	  Proprietary ARM Mali user-space driver wrappers.
	  Provides OpenGL ES, EGL, and GBM libraries.

if BR2_PACKAGE_LIBMALI

choice
	prompt "Mali GPU Type"
	default BR2_PACKAGE_LIBMALI_GPU_BIFROST_G31
	help
	  Select the specific Mali GPU model used by your board.

config BR2_PACKAGE_LIBMALI_GPU_BIFROST_G31
	bool "Bifrost G31 (H700, RK3326)"

config BR2_PACKAGE_LIBMALI_GPU_BIFROST_G52
	bool "Bifrost G52 (RK3566)"

endchoice

config BR2_PACKAGE_LIBMALI_GPU
	string
	default "bifrost-g31" if BR2_PACKAGE_LIBMALI_GPU_BIFROST_G31
	default "bifrost-g52" if BR2_PACKAGE_LIBMALI_GPU_BIFROST_G52

config BR2_PACKAGE_PROVIDES_LIBEGL
	default "libmali"

config BR2_PACKAGE_PROVIDES_LIBGLES
	default "libmali"

config BR2_PACKAGE_PROVIDES_LIBGBM
	default "libmali"

endif
