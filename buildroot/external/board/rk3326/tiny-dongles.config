# Enable USB Network and Wireless Subsystem
CONFIG_USB_NET_DRIVERS=y
CONFIG_CFG80211=m
CONFIG_MAC80211=m

# USB Bluetooth Drivers
CONFIG_BT_HCIBTUSB=m
CONFIG_BT_HCIBTUSB_BCM=y
CONFIG_BT_HCIBTUSB_MTK=y
CONFIG_BT_HCIBTUSB_RTL=y
CONFIG_BT_ATH3K=m

# Realtek USB Wi-Fi Drivers
CONFIG_WLAN_VENDOR_REALTEK=y
CONFIG_RTL_CARDS=m
CONFIG_RTL8192CU=m
CONFIG_RTL8XXXU=m
CONFIG_RTL8XXXU_UNTESTED=y
CONFIG_RTW88=m
CONFIG_RTW88_USB=m
CONFIG_RTW88_8821CU=m
CONFIG_RTW88_8723DU=m

# Realtek Staging USB Wi-Fi Drivers
CONFIG_R8712U=m
CONFIG_R8188EU=m
CONFIG_R8723AU=m

# MediaTek / Ralink USB Wi-Fi Drivers
CONFIG_WLAN_VENDOR_MEDIATEK=y
CONFIG_MT76_CORE=m
CONFIG_MT76_USB=m
CONFIG_MT7601U=m
CONFIG_MT76x0U=m
CONFIG_MT76x2U=m
CONFIG_MT7921_COMMON=m
CONFIG_MT7921U=m
CONFIG_MT7663U=m
CONFIG_MT7668U=m
CONFIG_WLAN_VENDOR_RALINK=y
CONFIG_RT2X00=m
CONFIG_RT2X00_LIB_USB=m
CONFIG_RT2800USB=m
CONFIG_RT2800USB_RT35XX=y
CONFIG_RT2800USB_RT53XX=y
CONFIG_RT2800USB_RT55XX=y
CONFIG_RT73USB=m
CONFIG_RT2500USB=m

# Atheros USB Wi-Fi
CONFIG_WLAN_VENDOR_ATH=y
CONFIG_ATH9K_HTC=m
CONFIG_CARL9170=m
CONFIG_ATH10K=m
CONFIG_ATH10K_USB=m

# Broadcom USB Wi-Fi
CONFIG_WLAN_VENDOR_BROADCOM=y
CONFIG_BRCMFMAC=m
CONFIG_BRCMFMAC_USB=y

# Legacy ZyDAS and Realtek Wi-Fi
CONFIG_ZD1211RW=m
CONFIG_RTL8187=m
