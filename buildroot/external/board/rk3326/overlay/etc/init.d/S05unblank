#!/bin/sh

start() {
	printf "Unblanking fb0: "
	if [ -w /sys/class/graphics/fb0/blank ]; then
		printf '%s\n' 0 > /sys/class/graphics/fb0/blank 2>/dev/null
		status=$?
	else
		status=0
	fi
	if [ $status -eq 0 ]; then
		echo "OK"
	else
		echo "FAIL"
	fi
	return $status
}

case "$1" in
	start)
		start
		;;
	stop|restart|reload)
		;;
	*)
		echo "Usage: $0 {start|stop|restart}"
		exit 1
esac
