# Minime libmali kernel config delta.
#
# This fragment is merged AFTER tiny-base.config + tiny-<board>.config and
# BEFORE olddefconfig, so anything set here overrides both.
#
# Used by Buildroot builds that use the proprietary ARM Mali user-space
# driver (libmali) with the mali-kbase kernel module.

# ── Disable Panfrost (proprietary Mali driver is used instead) ───────────
# CONFIG_DRM_PANFROST is not set

# ── Disable memory compaction (mali-kbase hangs with CONFIG_COMPACTION=y)
# CONFIG_COMPACTION is not set
