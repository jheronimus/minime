#!/bin/sh
# S05modules: Load modules listed in /etc/modules-load.d/*.conf
# This replaces systemd-modules-load in non-systemd builds.

case "$1" in
    start)
        if [ -d /etc/modules-load.d ]; then
            for conf in /etc/modules-load.d/*.conf; do
                [ -f "$conf" ] || continue
                while read -r mod; do
                    case "$mod" in
                        \#*) continue ;;
                        "") continue ;;
                    esac
                    printf "Loading module: %s\n" "$mod"
                    modprobe "$mod" 2>/dev/null || true
                done < "$conf"
            done
        fi
        ;;
    stop|restart|reload)
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|reload}" >&2
        exit 1
        ;;
esac

exit 0
