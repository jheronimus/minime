#!/bin/sh
#
# S10gpudriver: Load proprietary Mali GPU driver (libmali + mali-kbase).
#
# mali-kbase is built out-of-tree as a kernel module.  Page migration must
# be disabled at load time: with CONFIG_COMPACTION=y the module enables it
# by default (when large pages are on) and hangs at load.  The tiny-libmali
# config fragment disables CONFIG_COMPACTION, but the module parameter
# provides a safety net.

case "$1" in
    start)
        echo "Initializing GPU Subsystem..."
        echo "Activating libmali driver..."
        modprobe mali_kbase kbase_page_migration_enabled=0
        ;;
    stop)
        echo "Unloading GPU drivers..."
        rmmod mali_kbase 2>/dev/null
        ;;
    restart|reload)
        "$0" stop
        "$0" start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}" >&2
        exit 1
        ;;
esac

exit 0
