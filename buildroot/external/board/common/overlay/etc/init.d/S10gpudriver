#!/bin/sh
#
# S10gpudriver: Load GPU kernel drivers
#

case "$1" in
    start)
        echo "Initializing GPU Subsystem..."
        if [ -d /usr/lib/panfrost ]; then
            echo "Activating Panfrost driver..."
            modprobe panfrost
        else
            echo "Activating libmali driver..."
            modprobe mali_kbase
        fi
        ;;
    stop)
        echo "Unloading GPU drivers..."
        rmmod panfrost 2>/dev/null
        rmmod gpu_sched 2>/dev/null
        rmmod mali_kbase 2>/dev/null
        ;;
    restart|reload)
        "$0" stop
        "$0" start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}" >&2
        exit 1
        ;;
esac

exit 0
