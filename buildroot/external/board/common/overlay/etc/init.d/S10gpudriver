#!/bin/sh
#
# S10gpudriver: initialize open-source Panfrost GPU support.
#
# Panfrost is normally built into the kernel on Minime boards. If it is built
# as a module in a future config, load it opportunistically. Do not load the
# proprietary mali_kbase module: the Buildroot branch uses a musl toolchain and
# Mesa/Panfrost instead of the old glibc-only Mali blobs.

case "$1" in
    start)
        echo "Initializing Panfrost GPU support..."
        modprobe panfrost 2>/dev/null || true
        ;;
    stop)
        rmmod panfrost 2>/dev/null || true
        ;;
    restart|reload)
        "$0" stop
        "$0" start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}" >&2
        exit 1
        ;;
esac

exit 0
