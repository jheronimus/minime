#!/bin/sh
#
# S10gpudriver: Load GPU kernel drivers
#

case "$1" in
    start)
        echo "Initializing GPU Subsystem..."
        echo "Activating libmali driver..."
        # Force-disable page migration: with CONFIG_COMPACTION=y the module
        # enables it by default (when large pages are on) and hangs at load.
        # =0 keeps it off; harmless on boards without CONFIG_COMPACTION.
        modprobe mali_kbase kbase_page_migration_enabled=0
        ;;
    stop)
        echo "Unloading GPU drivers..."
        rmmod mali_kbase 2>/dev/null
        ;;
    restart|reload)
        "$0" stop
        "$0" start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}" >&2
        exit 1
        ;;
esac

exit 0
