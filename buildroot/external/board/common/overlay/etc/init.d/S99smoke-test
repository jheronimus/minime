#!/bin/sh

start() {
	if ! grep -q "minime_smoke_test=1" /proc/cmdline; then
		return 0
	fi

	echo "========================================="
	echo "  Minime Smoke Test (QEMU Emulation)     "
	echo "========================================="

	# Give the system some time to boot and services to start
	sleep 5

	PASSED=1
	REASON=""

	# 1. Check if the loop system erofs is mounted at /mnt/system
	if ! mountpoint -q /mnt/system; then
		PASSED=0
		REASON="system.erofs not mounted at /mnt/system"
	fi

	# 2. Check if SD card is mounted
	if ! mountpoint -q /mnt/sdcard; then
		PASSED=0
		REASON="SD card not mounted at /mnt/sdcard"
	fi

	# 3. Check UI log
	if [ $PASSED -eq 1 ]; then
		if [ -f /tmp/ui.log ]; then
			echo "--- UI LOGS ---"
			cat /tmp/ui.log
			echo "----------------"
			if grep -q -E "cannot open shared object file|so\..*not found|Segmentation fault" /tmp/ui.log; then
				PASSED=0
				REASON="UI crashed or has missing dynamic libraries"
			fi
		else
			PASSED=0
			REASON="/tmp/ui.log missing"
		fi
	fi

	if [ $PASSED -eq 1 ]; then
		echo "=== SMOKE TEST: PASSED ==="
	else
		echo "=== SMOKE TEST: FAILED ($REASON) ==="
	fi

	echo "========================================="
	
	# Force poweroff to exit QEMU
	poweroff -f
}

case "$1" in
	start)
		# Run in background after all other services have had a chance to start
		start &
		;;
	stop|restart|reload)
		;;
	*)
		echo "Usage: $0 {start|stop|restart}"
		exit 1
esac
