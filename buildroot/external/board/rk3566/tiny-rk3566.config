CONFIG_ARCH_ROCKCHIP=y
CONFIG_EFI_PARTITION=y
# Cortex-A55 correctness and runtime-detected architecture features
CONFIG_ARM64_ERRATUM_1024718=y
CONFIG_ARM64_ERRATUM_1530923=y
CONFIG_ARM64_ERRATUM_2441007=y
CONFIG_ARM64_HW_AFDBM=y
CONFIG_ARM64_CNP=y
CONFIG_ARM64_AMU_EXTN=y
CONFIG_SCHED_MC=y
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_COMPACTION=y
# Platform identity, monitoring, recovery, and diagnostics
CONFIG_NVMEM_ROCKCHIP_OTP=y
CONFIG_RTC_DRV_RK808=y
CONFIG_RTC_HCTOSYS=y
CONFIG_RTC_SYSTOHC=y
CONFIG_HWMON=y
CONFIG_IKCONFIG=y
CONFIG_IKCONFIG_PROC=y
CONFIG_DETECT_HUNG_TASK=y
CONFIG_WATCHDOG=y
CONFIG_DW_WATCHDOG=y
CONFIG_EXTRA_FIRMWARE="rtl_bt/rtl8821cs_fw.bin rtl_bt/rtl8821cs_config.bin rtw88/rtw8821c_fw.bin"
CONFIG_EXTRA_FIRMWARE_DIR="__MINIME_COMMON_FIRMWARE_DIR__"
# SCMI firmware interface (required by device tree)
CONFIG_ARM_SCMI_PROTOCOL=y
CONFIG_ARM_SCMI_POWER_DOMAIN=y
CONFIG_COMMON_CLK_SCMI=y
# IOMMU and power domains for GPU/display
CONFIG_ROCKCHIP_IOMMU=y
CONFIG_ROCKCHIP_PM_DOMAINS=y
CONFIG_MMC_BLOCK=y
CONFIG_MMC_BLOCK_MINORS=32
CONFIG_ROCKCHIP_IODOMAIN=y
CONFIG_I2C_RK3X=y
CONFIG_PL330_DMA=y
CONFIG_PHY_ROCKCHIP_INNO_USB2=y
CONFIG_PHY_ROCKCHIP_INNO_DSIDPHY=y
CONFIG_PHY_ROCKCHIP_NANENG_COMBO_PHY=y
CONFIG_USB_DWC3=y
CONFIG_USB_DWC3_OF_SIMPLE=y
CONFIG_USB_DWC3_GENERIC_PLAT=y
CONFIG_ROCKCHIP_DW_HDMI=y
CONFIG_ROCKCHIP_DW_MIPI_DSI=y
CONFIG_ROCKCHIP_THERMAL=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_PLTFM=y
CONFIG_MMC_SDHCI_OF_DWCMSHC=y
CONFIG_MMC_DW=y
CONFIG_MMC_DW_PLTFM=y
CONFIG_MMC_DW_ROCKCHIP=y
CONFIG_RTW88=y
CONFIG_RTW88_8821CS=y
CONFIG_DRM_ROCKCHIP=y
CONFIG_ROCKCHIP_VOP2=y
CONFIG_FRAMEBUFFER_CONSOLE_ROTATION=y
CONFIG_DRM_PANEL_SITRONIX_ST7703=y
CONFIG_DRM_PANEL_SITRONIX_ST7701=y
CONFIG_DRM_PANEL_SIMPLE=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_ROCKCHIP_SARADC=y
CONFIG_KEYBOARD_ADC=y
CONFIG_KEYBOARD_GPIO=y
CONFIG_MFD_RK8XX=y
CONFIG_MFD_RK8XX_I2C=y
CONFIG_COMMON_CLK_RK808=y
CONFIG_PINCTRL_RK805=y
CONFIG_REGULATOR_FAN53555=y
CONFIG_REGULATOR_RK808=y
CONFIG_POWER_RESET_GPIO=y
CONFIG_POWER_RESET_GPIO_RESTART=y
CONFIG_CHARGER_RK817=y
CONFIG_PWM_ROCKCHIP=y
CONFIG_BT_HCIUART_RTL=y
CONFIG_SND_SOC_ROCKCHIP_I2S_TDM=y
CONFIG_SND_SOC_RK817=y
CONFIG_SND_SOC_SIMPLE_AMPLIFIER=y
CONFIG_SND_SIMPLE_CARD=y
# Pstore/ramoops: capture kernel panic/oops logs across warm reboots so a
# crash (e.g. the multi-core Geekbench reset) leaves a trace to recover.
# The 1MB ramoops region is reserved by the DTS patch
# 0024-arm64-dts-rockchip-add-ramoops-reserved-memory-for-r.patch.
CONFIG_PSTORE=y
CONFIG_PSTORE_COMPRESS=y
CONFIG_PSTORE_CONSOLE=y
CONFIG_PSTORE_RAM=y
# Magic SysRq enabled to trigger a controlled panic (echo c >
# /proc/sysrq-trigger) for verifying pstore capture. Can be dropped after.
CONFIG_MAGIC_SYSRQ=y
