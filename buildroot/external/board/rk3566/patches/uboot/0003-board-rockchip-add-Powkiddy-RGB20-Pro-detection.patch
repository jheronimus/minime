From: ROCKNIX
Subject: [PATCH] board: rockchip: add Powkiddy RGB20 Pro detection

Imported from ROCKNIX RK3566 Generic U-Boot support and adapted for
U-Boot 2026.04 context.

Signed-off-by: ROCKNIX <noreply@rocknix.org>
---
 board/anbernic/rgxx3_rk3566/rgxx3-rk3566.c | 10 ++++++++++
 1 file changed, 10 insertions(+)

--- a/board/anbernic/rgxx3_rk3566/rgxx3-rk3566.c
+++ b/board/anbernic/rgxx3_rk3566/rgxx3-rk3566.c
@@ -60,6 +60,7 @@
 	RK2023,
 	RGARCD,
 	RGB10MAX3,
+	RGB20PRO,
 	/* Devices with duplicate ADC value */
 	RG353PS,
 	RG353VS,
@@ -139,6 +140,15 @@
 		.detect_panel = 0,
 		.detect_regulator = 1,
 		.uart_con = 0,
+	},
+	[RGB20PRO] = {
+		.adc_value = 245, /* Observed average from device */
+		.board = "rk3566-powkiddy-rgb20-pro",
+		.board_name = "Powkiddy RGB20 Pro",
+		.fdtfile = DTB_DIR "rk3566-powkiddy-rgb20-pro.dtb",
+		.detect_panel = 0,
+		.detect_regulator = 1,
+		.uart_con = 0,
 	},
 	/* Devices with duplicate ADC value */
 	[RG353PS] = {
