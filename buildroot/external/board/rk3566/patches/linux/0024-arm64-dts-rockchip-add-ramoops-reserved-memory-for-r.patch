From 95c8a1f3e2b4d5a6b7c8d9e0f1a2b3c4d5e6f7a8 Mon Sep 17 00:00:00 2001
From: jheronimus <jheronimus@users.noreply.github.com>
Date: Thu, 18 Jun 2026 22:30:00 +0300
Subject: [PATCH] arm64: dts: rockchip: add ramoops reserved-memory for rk356x

Add a 1MB ramoops region at 0x60000000 so pstore can capture kernel
panic/oops logs across warm reboots. The address sits within the 2GB
System RAM (0x200000-0x80000000) in the free gap between kernel data
and the CMA allocation; no-map keeps the kernel off it. console-size
256KB captures the full console log; record-size 128KB allows six
dmesg dump records in the remaining space.

---
 arch/arm64/boot/dts/rockchip/rk356x-base.dtsi | 8 ++++++++
 1 file changed, 8 insertions(+)

diff --git a/arch/arm64/boot/dts/rockchip/rk356x-base.dtsi b/arch/arm64/boot/dts/rockchip/rk356x-base.dtsi
--- a/arch/arm64/boot/dts/rockchip/rk356x-base.dtsi
+++ b/arch/arm64/boot/dts/rockchip/rk356x-base.dtsi
@@ -192,5 +192,13 @@
 			linux,cma-default;
 		};
+		ramoops@60000000 {
+			compatible = "ramoops";
+			reg = <0x0 0x60000000 0x0 0x100000>;
+			record-size = <0x0 0x20000>;
+			console-size = <0x0 0x40000>;
+			no-map;
+		};
 	};
 
 	timer {
--
2.45.1
